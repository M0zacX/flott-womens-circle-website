---
const features = [
  { title: "Wellness Education", description: "Body & Mind", image: "/images/flott-03.jpeg" },
  { title: "Soft Skills Acquisition", description: "Growth", image: "/images/flott-07.jpeg" },
  { title: "Women Empowerment", description: "Strength", image: "/images/flott-09.jpeg" },
  { title: "Community & Connection", description: "Together", image: "/images/flott-12.jpeg" },
  { title: "Cultural Wellness", description: "Heritage", image: "/images/flott-16.jpeg" },
  { title: "Guided Conversations", description: "Clarity", image: "/images/flott-18.jpeg" },
];
---

<section id="focus-areas" class="bg-background relative overflow-hidden">
  <!-- Decorative spiral vine -->
  <svg class="absolute -top-20 -left-16 w-[320px] h-[460px] text-[#e8b4b8] opacity-50 pointer-events-none hidden lg:block" viewBox="0 0 350 500" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <path d="M175 480 C175 420 140 380 160 320 C180 260 120 240 140 180 C160 120 200 140 190 80 C182 40 150 20 175 10" />
    <path d="M175 10 C220 10 260 50 250 100 C240 150 190 140 190 80" />
    <path d="M200 50 C220 50 236 70 230 90 C224 110 204 105 204 80" />
    <path d="M160 320 C130 300 110 310 100 290" /><path d="M100 290 C110 300 108 316 120 312" />
    <path d="M160 320 C190 300 210 310 220 290" /><path d="M220 290 C210 300 212 316 200 312" />
    <path d="M160 320 C140 308 118 302 100 290" opacity="0.5" />
    <path d="M160 320 C180 308 202 302 220 290" opacity="0.5" />
    <path d="M140 180 C110 170 90 190 100 210 C110 230 135 220 130 200" />
    <path d="M130 240 C100 228 82 238 72 222" /><path d="M130 240 C160 228 178 238 188 222" />
    <path d="M170 400 C200 390 220 400 218 420 C216 440 196 435 198 418" />
    <path d="M218 420 C232 410 244 416 240 428" />
    <circle cx="100" cy="286" r="2.5" /><circle cx="220" cy="286" r="2.5" />
    <circle cx="72" cy="218" r="2.5" /><circle cx="188" cy="218" r="2.5" />
    <circle cx="240" cy="432" r="2.5" />
  </svg>

  <div class="px-6 py-20 text-center md:px-12 md:py-28 lg:px-20 lg:py-32 lg:pb-20">
    <h2 class="word-blur-group text-3xl font-medium tracking-tight text-foreground md:text-4xl lg:text-5xl">
      <span class="word-blur" style="transition-delay: 0s">Rooted</span>
      <span class="word-blur" style="transition-delay: 0.1s">in</span>
      <span class="word-blur" style="transition-delay: 0.2s">Wellness.</span>
      <span class="word-blur" style="transition-delay: 0.35s">Designed</span>
      <span class="word-blur" style="transition-delay: 0.45s">for</span>
      <span class="word-blur" style="transition-delay: 0.6s; font-family: 'Playfair Display', serif; font-style: italic; font-weight: 500;">Growth.</span>
    </h2>
    <p class="blur-words mx-auto mt-6 max-w-md text-sm text-muted-foreground">What We Do</p>
  </div>

  <div class="grid grid-cols-1 gap-4 px-6 pb-20 md:grid-cols-3 md:px-12 lg:px-20">
    {features.map((feature, index) => (
      <div class="reveal group" style={`transition-delay: ${index * 0.15}s`}>
        <div class="relative aspect-[4/3] overflow-hidden rounded-2xl reveal-clip" style={`transition-delay: ${0.1 + index * 0.15}s`}>
          <img
            src={feature.image}
            alt={feature.title}
            class="fade-image absolute inset-0 w-full h-full object-cover hover-zoom"
            loading="lazy"
            onload="this.classList.add('loaded')"
          />
        </div>
        <div class="py-6">
          <p class="reveal mb-2 text-xs uppercase tracking-widest text-muted-foreground" style={`transition-delay: ${0.15 + index * 0.15}s`}>{feature.description}</p>
          <h3 class="reveal-flip text-foreground text-xl font-semibold" style={`transition-delay: ${0.2 + index * 0.15}s`}>{feature.title}</h3>
        </div>
      </div>
    ))}
  </div>

  <div class="flex justify-center px-6 pb-28 md:px-12 lg:px-20"></div>
</section>
