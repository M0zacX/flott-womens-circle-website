---
const team = [
  { name: "Safiya Umar", role: "Founder & Group CEO", image: "/images/team/safiya-umar-founder-&-group-ceo.webp", featured: true },
  { name: "Rita Ogbuagu", role: "CEO, Flott Beauty Port Harcourt", image: "/images/team/rita-ogbuagu-ceo-flott-beauty-portharcourt.webp" },
  { name: "Maimuna Yakubu Adejoh", role: "CEO, Flott Beauty Kaduna", image: "/images/team/maimuna-yakubu-adejoh-ceo-flott-beauty-kaduna.webp" },
  { name: "Emek Akpan", role: "Co-CEO, Flott Beauty Port Harcourt", image: "/images/team/emek-akpan-co-ceo-flott-beauty-portharcourt.webp" },
  { name: "Fatima Abubbakar", role: "CEO, Flott Beauty Ilorin", image: "/images/team/fatima-abubbakar-ceo-flott-beauty-ilorin.webp" },
  { name: "Dr. Jane Onyeanusi", role: "CEO, Flott Beauty Enugu", image: "/images/team/dr.jane-onyeanusi-ceo-flott-beauty-enugu.webp" },
  { name: "Silvia Aboh", role: "Chief Head of Operations", image: "/images/team/silvia-aboh-chief-head-of-operations.webp" },
];
---

<section class="bg-background relative">
  <div class="grid grid-cols-1 lg:grid-cols-2">
    <!-- Left sticky column -->
    <div class="relative px-6 py-14 md:px-12 md:py-20 lg:sticky lg:top-0 lg:h-screen lg:flex lg:flex-col lg:justify-center lg:px-20 lg:py-0">
      <!-- Ornate Henna Vine — flowing vine with folk flowers -->
      <svg class="absolute bottom-8 right-4 w-[240px] h-[360px] md:w-[280px] md:h-[420px] text-[#e8b4b8] opacity-[0.35] pointer-events-none" viewBox="0 0 300 450" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <!-- Main flowing vine -->
        <path d="M150 440 C150 400 120 370 130 320 C140 270 100 250 115 200 C130 150 160 160 150 110 C142 70 120 50 140 20" />
        <!-- Large folk flower at top -->
        <circle cx="140" cy="20" r="5" /><circle cx="140" cy="20" r="12" />
        <path d="M140 5 Q146 -8 140 -18 Q134 -8 140 5Z" />
        <path d="M155 14 Q168 8 174 -2 Q162 6 155 14Z" />
        <path d="M157 30 Q170 36 178 30 Q166 30 157 30Z" />
        <path d="M150 38 Q156 50 150 60 Q144 50 150 38Z" />
        <path d="M128 34 Q116 42 108 38 Q118 34 128 34Z" />
        <path d="M125 18 Q112 12 106 0 Q118 8 125 18Z" />
        <circle cx="140" cy="-22" r="2" /><circle cx="176" cy="-4" r="2" /><circle cx="182" cy="30" r="2" />
        <circle cx="150" cy="64" r="2" /><circle cx="104" cy="40" r="2" /><circle cx="102" cy="-2" r="2" />
        <!-- Concentric circles inside top flower -->
        <path d="M140 20 C140 15 145 12 148 14 C151 16 150 22 147 23 C144 24 139 22 139 18" />
        <!-- Paisley curl from top -->
        <path d="M140 20 C170 15 190 30 185 52 C180 74 158 68 162 50" />
        <path d="M175 40 C182 36 188 40 186 48" />
        <circle cx="188" cy="50" r="2" />
        <!-- Medium folk flower at middle (~200) -->
        <circle cx="115" cy="200" r="4" /><circle cx="115" cy="200" r="10" />
        <path d="M115 186 Q120 174 115 164 Q110 174 115 186Z" />
        <path d="M128 194 Q140 188 146 178 Q134 186 128 194Z" />
        <path d="M128 206 Q140 212 146 222 Q134 214 128 206Z" />
        <path d="M115 214 Q120 226 115 236 Q110 226 115 214Z" />
        <path d="M102 206 Q90 212 84 222 Q96 214 102 206Z" />
        <path d="M102 194 Q90 188 84 178 Q96 186 102 194Z" />
        <circle cx="115" cy="160" r="2" /><circle cx="150" cy="176" r="2" />
        <circle cx="150" cy="224" r="2" /><circle cx="115" cy="240" r="2" />
        <circle cx="80" cy="224" r="2" /><circle cx="80" cy="176" r="2" />
        <!-- Leaf pairs along vine -->
        <path d="M130 320 C105 305 90 312 86 298 C82 284 100 278 130 300" />
        <path d="M130 308 C110 298 92 294 86 298" opacity="0.5" />
        <path d="M130 320 C155 305 170 312 174 298 C178 284 160 278 130 300" />
        <path d="M130 308 C150 298 168 294 174 298" opacity="0.5" />
        <!-- Small leaves -->
        <path d="M145 140 C160 130 168 136 164 148" />
        <path d="M145 140 C158 134 166 138 164 148" opacity="0.4" />
        <path d="M125 270 C108 262 100 268 104 278" />
        <path d="M125 270 C110 264 102 270 104 278" opacity="0.4" />
        <!-- Spiral tendril offshoots -->
        <path d="M140 360 C168 350 182 360 180 380 C178 400 160 394 162 378" />
        <path d="M180 380 C192 372 200 378 196 388" />
        <circle cx="198" cy="390" r="2" />
        <!-- Small geometric flower on tendril -->
        <circle cx="180" cy="380" r="3" />
        <path d="M180 374 L182 368 L180 362 L178 368Z" />
        <path d="M186 377 L192 375 L196 378 L190 380Z" />
        <path d="M186 383 L192 385 L196 382 L190 380Z" />
        <path d="M180 386 L182 392 L180 398 L178 392Z" />
        <path d="M174 383 L168 385 L164 382 L170 380Z" />
        <path d="M174 377 L168 375 L164 378 L170 380Z" />
        <!-- Dot trail accents -->
        <circle cx="86" cy="294" r="2.5" /><circle cx="174" cy="294" r="2.5" />
        <circle cx="135" cy="350" r="1.5" /><circle cx="128" cy="380" r="1.5" /><circle cx="140" cy="400" r="1.5" />
        <!-- Small hydrangea cluster near bottom -->
        <circle cx="108" cy="410" r="4" /><circle cx="118" cy="405" r="4" /><circle cx="113" cy="415" r="4" />
        <circle cx="103" cy="418" r="3" /><circle cx="123" cy="413" r="3" /><circle cx="108" cy="424" r="3" />
      </svg>

      <!-- Small top-left accent — geometric bloom -->
      <svg class="absolute top-12 left-6 w-[80px] h-[80px] md:w-[100px] md:h-[100px] text-[#e8b4b8] opacity-[0.25] pointer-events-none hidden md:block" viewBox="0 0 100 100" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <circle cx="50" cy="50" r="4" />
        <path d="M50 42 Q54 30 50 20 Q46 30 50 42Z" />
        <path d="M58 46 Q68 40 74 32 Q64 38 58 46Z" />
        <path d="M58 54 Q68 60 74 68 Q64 62 58 54Z" />
        <path d="M50 58 Q54 70 50 80 Q46 70 50 58Z" />
        <path d="M42 54 Q32 60 26 68 Q36 62 42 54Z" />
        <path d="M42 46 Q32 40 26 32 Q36 38 42 46Z" />
        <circle cx="50" cy="16" r="1.5" /><circle cx="76" cy="30" r="1.5" /><circle cx="76" cy="70" r="1.5" />
        <circle cx="50" cy="84" r="1.5" /><circle cx="24" cy="70" r="1.5" /><circle cx="24" cy="30" r="1.5" />
      </svg>
      <p class="blur-words text-xs uppercase tracking-[0.3em] text-muted-foreground mb-4" style="font-style: italic">The Women Behind It</p>
      <h2 class="word-blur-group text-3xl font-medium tracking-tight text-foreground md:text-4xl lg:text-5xl">
        <span class="word-blur" style="transition-delay: 0.1s">Women</span>
        <span class="word-blur" style="transition-delay: 0.2s">Who</span>
        <span class="word-blur" style="transition-delay: 0.3s">Hold</span>
        <span class="word-blur" style="transition-delay: 0.45s; font-family: 'Playfair Display', serif; font-style: italic; font-weight: 500;">Space</span>
      </h2>

      <p class="blur-words mt-8 text-sm leading-relaxed text-muted-foreground max-w-md">
        Every Circle is led by a woman who shows up with care, intention, and heart.
      </p>
      <p class="blur-words mt-4 text-sm leading-relaxed text-muted-foreground max-w-md">
        No hierarchy. No titles for show. Just women who believe in this work and do it with purpose.
      </p>

      <div class="mt-10 border-t border-border"></div>

      <div class="mt-10 grid grid-cols-2 gap-8">
        <div class="reveal" style="transition-delay: 0.4s">
          <div class="mb-4 flex h-12 w-12 items-center justify-center rounded-full border border-border">
            <svg class="h-6 w-6 text-[#c49298]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round">
              <!-- Lotus bloom -->
              <path d="M12 20c0-4-3-7-3-10s3-6 3-6 3 3 3 6-3 6-3 10z" />
              <path d="M12 20c-2-3-6-5-8-5 2-1 5 0 8 5z" />
              <path d="M12 20c2-3 6-5 8-5-2-1-5 0-8 5z" />
              <circle cx="12" cy="7" r="1.5" fill="currentColor" opacity="0.3" />
            </svg>
          </div>
          <h3 class="text-sm font-semibold text-foreground">Values-Based Leadership</h3>
          <p class="mt-3 text-xs leading-relaxed text-muted-foreground">
            Each Lead carries the mission forward while honouring her community's unique rhythm.
          </p>
        </div>
        <div class="reveal" style="transition-delay: 0.5s">
          <div class="mb-4 flex h-12 w-12 items-center justify-center rounded-full border border-border">
            <svg class="h-6 w-6 text-[#c49298]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round">
              <!-- Roots & branches — five connected -->
              <path d="M12 6v12" />
              <path d="M12 6c-2-3-5-4-7-3" />
              <path d="M12 6c2-3 5-4 7-3" />
              <path d="M12 6c-1-2-1-4 0-5" />
              <path d="M12 18c-2 2-5 3-7 2" />
              <path d="M12 18c2 2 5 3 7 2" />
              <circle cx="5" cy="3" r="1.5" fill="currentColor" opacity="0.3" />
              <circle cx="19" cy="3" r="1.5" fill="currentColor" opacity="0.3" />
              <circle cx="12" cy="1" r="1.5" fill="currentColor" opacity="0.3" />
              <circle cx="5" cy="20" r="1.5" fill="currentColor" opacity="0.3" />
              <circle cx="19" cy="20" r="1.5" fill="currentColor" opacity="0.3" />
            </svg>
          </div>
          <h3 class="text-sm font-semibold text-foreground">Local Roots, Shared Vision</h3>
          <p class="mt-3 text-xs leading-relaxed text-muted-foreground">
            Four cities, one mission — helping women know themselves, care for themselves, and grow.
          </p>
        </div>
      </div>
    </div>

    <!-- Right scrolling column -->
    <div class="grid grid-cols-2 gap-4 px-6 pb-14 md:pb-20 md:px-12 lg:px-4 lg:pr-20 lg:py-20">
      {team.map((member, index) => (
        member.featured ? (
          <div class="col-span-2 reveal group" style={`transition-delay: ${index * 0.15}s`}>
            <div class="relative overflow-hidden rounded-2xl flex" style="min-height: 340px;">
              <div class="relative shrink-0 overflow-hidden" style="width: 42%; min-height: 340px;">
                <img
                  src={member.image}
                  alt={member.name}
                  class="absolute inset-0 w-full h-full object-cover hover-zoom"
                  style="object-position: center 20%;"
                />
              </div>
              <div class="relative flex flex-col justify-between flex-1 p-6 md:p-8 overflow-hidden" style="background: #0F0906;">
                <!-- Decorative botanical SVG watermark -->
                <svg class="absolute -bottom-6 -right-6 w-[180px] h-[260px] pointer-events-none" style="color: #e8b4b8; opacity: 0.12;" viewBox="0 0 300 450" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="M150 440 C150 400 120 370 130 320 C140 270 100 250 115 200 C130 150 160 160 150 110 C142 70 120 50 140 20" />
                  <circle cx="140" cy="20" r="5" /><circle cx="140" cy="20" r="12" />
                  <path d="M140 5 Q146 -8 140 -18 Q134 -8 140 5Z" />
                  <path d="M155 14 Q168 8 174 -2 Q162 6 155 14Z" />
                  <path d="M157 30 Q170 36 178 30 Q166 30 157 30Z" />
                  <path d="M150 38 Q156 50 150 60 Q144 50 150 38Z" />
                  <path d="M128 34 Q116 42 108 38 Q118 34 128 34Z" />
                  <path d="M125 18 Q112 12 106 0 Q118 8 125 18Z" />
                  <circle cx="115" cy="200" r="4" /><circle cx="115" cy="200" r="10" />
                  <path d="M115 186 Q120 174 115 164 Q110 174 115 186Z" />
                  <path d="M128 194 Q140 188 146 178 Q134 186 128 194Z" />
                  <path d="M128 206 Q140 212 146 222 Q134 214 128 206Z" />
                  <path d="M115 214 Q120 226 115 236 Q110 226 115 214Z" />
                  <path d="M102 206 Q90 212 84 222 Q96 214 102 206Z" />
                  <path d="M102 194 Q90 188 84 178 Q96 186 102 194Z" />
                  <path d="M130 320 C105 305 90 312 86 298 C82 284 100 278 130 300" />
                  <path d="M130 320 C155 305 170 312 174 298 C178 284 160 278 130 300" />
                  <path d="M140 360 C168 350 182 360 180 380 C178 400 160 394 162 378" />
                </svg>

                <p class="text-xs uppercase tracking-[0.3em] text-white/40 relative z-10" style="font-style: italic">Founder</p>

                <p class="relative z-10 text-white/20 text-sm leading-relaxed max-w-[180px]" style="font-family: 'Playfair Display', serif; font-style: italic;">
                  "Rooted in wellness.<br/>Growing in community."
                </p>

                <div class="relative z-10">
                  <p class="text-xl md:text-2xl font-medium text-white tracking-tight leading-tight">{member.name}</p>
                  <p class="text-sm text-white/50 mt-2">{member.role}</p>
                  <div class="mt-4 w-8 h-px" style="background: rgba(255,255,255,0.15);"></div>
                </div>
              </div>
            </div>
          </div>
        ) : (
          <div class="reveal group" style={`transition-delay: ${index * 0.15}s`}>
            <div class="relative aspect-[3/4] overflow-hidden rounded-2xl">
              <img
                src={member.image}
                alt={member.name}
                class="absolute inset-0 w-full h-full object-cover object-center hover-zoom"
              />
              <div class="absolute inset-x-0 bottom-0 p-4">
                <div class="backdrop-blur-md rounded-xl px-4 py-3" style="background: rgba(0, 0, 0, 0.45); border: 1px solid rgba(255, 255, 255, 0.1)">
                  <p class="text-white text-sm font-medium">{member.name}</p>
                  <p class="text-white/60 text-xs mt-0.5">{member.role}</p>
                </div>
              </div>
            </div>
          </div>
        )
      ))}
    </div>
  </div>
</section>
