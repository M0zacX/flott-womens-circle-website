---
const stats = [
  { value: "12K", label: "Community Members" },
  { value: "8", label: "Years of Impact" },
  { value: "99%", label: "Member Satisfaction" },
  { value: "24", label: "Countries Reached" },
];
---

<section class="bg-foreground py-28 md:py-36 lg:py-44">
  <div class="px-6 md:px-12 lg:px-20">
    <div class="text-center mb-20">
      <p class="reveal text-xs uppercase tracking-[0.3em] text-white/40 mb-6" style="font-style: italic">Key Facts</p>
      <h2 class="reveal-flip text-3xl font-medium tracking-tight text-white md:text-4xl lg:text-5xl" style="transition-delay: 0.1s">
        Highlights of Our Journey <span style="font-family: 'Playfair Display', serif; font-style: italic; font-weight: 500;">Together</span>
      </h2>
    </div>

    <div class="mx-auto flex justify-center items-center">
      {stats.map((stat, index) => (
        <div class="reveal flex flex-col items-center" style={`transition-delay: ${0.2 + index * 0.12}s; margin-left: ${index > 0 ? '-3rem' : '0'}`}>
          <div class="relative flex flex-col items-center justify-center w-44 h-44 md:w-56 md:h-56 lg:w-64 lg:h-64 rounded-full border border-white/15" style={`background: rgba(15, 9, 6, ${0.85 - index * 0.15})`}>
            <span class="text-white text-4xl md:text-5xl lg:text-6xl" style="font-family: 'Playfair Display', serif; font-style: italic; font-weight: 500">
              {stat.value}
            </span>
            <p class="mt-2 text-[10px] md:text-xs uppercase tracking-[0.15em] text-white/40">{stat.label}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
