---
const specs = [
  { label: "Weight", value: "400g" },
  { label: "Capacity", value: "0.5L - 2L" },
  { label: "Setup", value: "2 min" },
  { label: "Packed size", value: "30 x 15 cm" },
];
---

<section class="bg-background">
  <div class="flex items-center justify-center gap-6 pb-20"></div>

  <div class="grid grid-cols-2 border-t border-border md:grid-cols-4">
    {specs.map((spec) => (
      <div class="border-b border-r border-border p-8 text-center last:border-r-0 md:border-b-0">
        <p class="mb-2 text-xs uppercase tracking-widest text-muted-foreground">{spec.label}</p>
        <p class="font-medium text-foreground text-4xl">{spec.value}</p>
      </div>
    ))}
  </div>

  <div class="relative aspect-[16/9] w-full md:aspect-[21/9]">
    <img src="/images/flott-23.jpeg" alt="Flott Women's Circle community moment" class="absolute inset-0 w-full h-full object-cover" />
  </div>
</section>
