  <circle cx="72" cy="218" r="2.5" /><circle cx="188" cy="218" r="2.5" />
  <circle cx="240" cy="432" r="2.5" />
  <circle cx="250" cy="100" r="2" /><circle cx="230" cy="92" r="1.5" />
</svg>
</Fragment>

<!-- 3. Geometric Bloom — star-shaped folk flower with radiating petals -->
<Fragment slot="geometric-bloom">
<svg viewBox="0 0 300 300" fill="none" xmlns="http://www.w3.org/2000/svg" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round">
  <!-- Center -->
  <circle cx="150" cy="150" r="10" />
  <circle cx="150" cy="150" r="4" />
  <!-- Inner star petals (6-pointed) -->
  <path d="M150 140 L155 118 L150 96 L145 118Z" />
  <path d="M160 145 L178 134 L196 130 L178 140Z" />
  <path d="M160 155 L178 160 L196 170 L178 156Z" />
  <path d="M150 160 L155 182 L150 204 L145 182Z" />
  <path d="M140 155 L122 160 L104 170 L122 156Z" />
  <path d="M140 145 L122 134 L104 130 L122 140Z" />
  <!-- Radiating lines between petals -->
  <line x1="150" y1="90" x2="150" y2="60" />
  <line x1="202" y1="120" x2="226" y2="106" />
  <line x1="202" y1="180" x2="226" y2="194" />
  <line x1="150" y1="210" x2="150" y2="240" />
  <line x1="98" y1="180" x2="74" y2="194" />
  <line x1="98" y1="120" x2="74" y2="106" />
  <!-- Outer dots at line ends -->
  <circle cx="150" cy="56" r="3" /><circle cx="228" cy="104" r="3" />
  <circle cx="228" cy="196" r="3" /><circle cx="150" cy="244" r="3" />
  <circle cx="72" cy="196" r="3" /><circle cx="72" cy="104" r="3" />
  <!-- Decorative arc segments between dots -->
  <path d="M156 58 Q192 68 224 106" fill="none" />
  <path d="M230 110 Q244 148 230 192" fill="none" />
  <path d="M224 198 Q192 232 156 242" fill="none" />
  <path d="M144 242 Q108 232 76 198" fill="none" />
  <path d="M70 192 Q56 148 70 110" fill="none" />
  <path d="M76 106 Q108 68 144 58" fill="none" />
  <!-- Tiny accent marks on arcs -->
  <line x1="190" y1="72" x2="194" y2="68" /><line x1="240" y1="150" x2="246" y2="150" />
  <line x1="190" y1="228" x2="194" y2="232" /><line x1="110" y1="228" x2="106" y2="232" />
  <line x1="60" y1="150" x2="54" y2="150" /><line x1="110" y1="72" x2="106" y2="68" />
</svg>
</Fragment>

