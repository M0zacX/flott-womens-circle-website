---
const programs = [
  { id: 1, name: "Wellness Education Sessions", description: "Body care and self-care workshops focused on holistic wellbeing", image: "/images/flott-44.jpeg" },
  { id: 2, name: "Soft Skills Circles", description: "Communication, confidence, emotional intelligence, and self-presentation", image: "/images/flott-46.jpeg" },
  { id: 3, name: "Empowerment Gatherings", description: "Mental, social, economic, and financial empowerment sessions", image: "/images/flott-48.jpeg" },
  { id: 4, name: "Cultural Wellness", description: "Traditional and modern self-care practices integrated into daily life", image: "/images/flott-50.jpeg" },
  { id: 5, name: "Growth Conversations", description: "Guided discussions on self-awareness, identity, and womanhood", image: "/images/flott-52.jpeg" },
  { id: 6, name: "Community Events", description: "Seasonal gatherings that uplift, inspire, and strengthen bonds", image: "/images/flott-54.jpeg" },
];
---

<section id="programs" class="bg-background relative overflow-hidden">
  <!-- Scandinavian Folk Dahlia — intricate multi-layered flower -->
  <svg class="absolute -top-12 -right-16 w-[340px] h-[460px] text-[#e8b4b8] opacity-[0.4] pointer-events-none hidden lg:block" viewBox="0 0 340 460" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <!-- Stem -->
    <path d="M170 460 C170 420 165 380 170 340 C175 300 168 270 170 240" />
    <!-- Stem leaves — alternating -->
    <path d="M170 380 C148 365 132 372 130 358 C128 344 145 338 170 360" />
    <path d="M170 360 C145 350 130 355 130 358" opacity="0.5" />
    <path d="M170 330 C192 315 208 322 210 308 C212 294 195 288 170 310" />
    <path d="M170 310 C195 300 210 305 210 308" opacity="0.5" />
    <!-- Small stem buds -->
    <path d="M170 410 C180 400 188 404 186 414" />
    <circle cx="188" cy="416" r="2" />
    <!-- Center — concentric circles with spiral -->
    <circle cx="170" cy="170" r="6" />
    <path d="M170 170 C170 164 176 160 182 163 C188 166 186 176 180 178 C174 180 166 176 165 170 C164 164 170 158 178 158 C186 158 192 166 190 174 C188 182 178 186 172 184" />
    <circle cx="170" cy="170" r="22" />
    <!-- Inner dot ring -->
    <circle cx="170" cy="146" r="2.5" /><circle cx="194" cy="158" r="2.5" /><circle cx="194" cy="182" r="2.5" />
    <circle cx="170" cy="194" r="2.5" /><circle cx="146" cy="182" r="2.5" /><circle cx="146" cy="158" r="2.5" />
    <!-- Inner pointed star petals — 6 -->
    <path d="M170 142 L175 122 L170 100 L165 122Z" />
    <path d="M192 156 L210 148 L228 146 L210 154Z" />
    <path d="M192 184 L210 192 L228 194 L210 186Z" />
    <path d="M170 198 L175 218 L170 240 L165 218Z" />
    <path d="M148 184 L130 192 L112 194 L130 186Z" />
    <path d="M148 156 L130 148 L112 146 L130 154Z" />
    <!-- Middle ring -->
    <circle cx="170" cy="170" r="52" />
    <!-- Zigzag decoration on middle ring -->
    <path d="M170 118 L175 112 L180 118 L185 112 L190 118" opacity="0.6" />
    <path d="M222 155 L228 150 L222 145 L228 140" opacity="0.6" transform="rotate(60 170 170)" />
    <path d="M222 155 L228 150 L222 145 L228 140" opacity="0.6" transform="rotate(120 170 170)" />
    <path d="M222 155 L228 150 L222 145 L228 140" opacity="0.6" transform="rotate(180 170 170)" />
    <path d="M222 155 L228 150 L222 145 L228 140" opacity="0.6" transform="rotate(240 170 170)" />
    <path d="M222 155 L228 150 L222 145 L228 140" opacity="0.6" transform="rotate(300 170 170)" />
    <!-- Outer rounded petals — 12 -->
    <path d="M170 116 Q180 88 170 62 Q160 88 170 116Z" />
    <path d="M193 122 Q214 102 218 74 Q200 96 193 122Z" />
    <path d="M216 148 Q244 142 262 122 Q238 140 216 148Z" />
    <path d="M222 170 Q250 170 272 156 Q248 166 222 170Z" />
    <path d="M216 192 Q244 198 262 218 Q238 200 216 192Z" />
    <path d="M193 218 Q214 238 218 266 Q200 244 193 218Z" />
    <path d="M170 224 Q180 252 170 278 Q160 252 170 224Z" />
    <path d="M147 218 Q126 238 122 266 Q140 244 147 218Z" />
    <path d="M124 192 Q96 198 78 218 Q102 200 124 192Z" />
    <path d="M118 170 Q90 170 68 156 Q92 166 118 170Z" />
    <path d="M124 148 Q96 142 78 122 Q102 140 124 148Z" />
    <path d="M147 122 Q126 102 122 74 Q140 96 147 122Z" />
    <!-- Outer ring -->
    <circle cx="170" cy="170" r="88" />
    <!-- Outermost spade-shaped petals — 8 -->
    <path d="M170 80 Q184 52 170 24 Q156 52 170 80" />
    <path d="M232 102 Q254 82 256 52 Q238 78 232 102" />
    <path d="M258 170 Q288 170 302 148 Q282 164 258 170" />
    <path d="M232 238 Q254 258 256 288 Q238 262 232 238" />
    <path d="M170 260 Q184 288 170 316 Q156 288 170 260" />
    <path d="M108 238 Q86 258 84 288 Q102 262 108 238" />
    <path d="M82 170 Q52 170 38 148 Q58 164 82 170" />
    <path d="M108 102 Q86 82 84 52 Q102 78 108 102" />
    <!-- Tiny dots at petal tips -->
    <circle cx="170" cy="20" r="2.5" /><circle cx="258" cy="48" r="2.5" /><circle cx="306" cy="146" r="2.5" />
    <circle cx="258" cy="292" r="2.5" /><circle cx="170" cy="320" r="2.5" /><circle cx="82" cy="292" r="2.5" />
    <circle cx="34" cy="146" r="2.5" /><circle cx="82" cy="48" r="2.5" />
    <!-- Connecting arcs between outermost petal tips -->
    <path d="M174 22 Q216 26 254 50" fill="none" opacity="0.5" />
    <path d="M260 52 Q292 88 304 144" fill="none" opacity="0.5" />
    <path d="M304 150 Q298 218 260 286" fill="none" opacity="0.5" />
    <path d="M254 290 Q216 314 174 318" fill="none" opacity="0.5" />
    <path d="M166 318 Q124 314 86 290" fill="none" opacity="0.5" />
    <path d="M80 286 Q42 218 36 150" fill="none" opacity="0.5" />
    <path d="M36 144 Q48 88 80 52" fill="none" opacity="0.5" />
    <path d="M86 50 Q124 26 166 22" fill="none" opacity="0.5" />
  </svg>

  <!-- Small scattered folk rosette — bottom left -->
  <svg class="absolute bottom-12 left-6 w-[120px] h-[120px] md:w-[160px] md:h-[160px] text-[#e8b4b8] opacity-[0.3] pointer-events-none" viewBox="0 0 200 200" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <circle cx="100" cy="100" r="8" /><circle cx="100" cy="100" r="3" />
    <path d="M100 88 Q106 72 100 58 Q94 72 100 88Z" />
    <path d="M112 94 Q126 86 134 72 Q122 82 112 94Z" />
    <path d="M112 106 Q126 114 134 128 Q122 118 112 106Z" />
    <path d="M100 112 Q106 128 100 142 Q94 128 100 112Z" />
    <path d="M88 106 Q74 114 66 128 Q78 118 88 106Z" />
    <path d="M88 94 Q74 86 66 72 Q78 82 88 94Z" />
    <circle cx="100" cy="54" r="2" /><circle cx="136" cy="68" r="2" /><circle cx="136" cy="132" r="2" />
    <circle cx="100" cy="146" r="2" /><circle cx="64" cy="132" r="2" /><circle cx="64" cy="68" r="2" />
  </svg>

  <div class="px-6 py-20 md:px-12 lg:px-20 md:py-10">
    <h2 class="word-blur-group text-3xl font-medium tracking-tight text-foreground md:text-4xl">
      <span class="word-blur" style="transition-delay: 0s">Our</span>
      <span class="word-blur" style="transition-delay: 0.15s; font-family: 'Playfair Display', serif; font-style: italic; font-weight: 500;">Programs</span>
    </h2>
  </div>

  <div class="pb-24">
    <!-- Mobile: horizontal scroll -->
    <div class="flex gap-6 overflow-x-auto px-6 pb-4 md:hidden snap-x snap-mandatory scrollbar-hide">
      {programs.map((program) => (
        <div class="group flex-shrink-0 w-[75vw] snap-center">
          <div class="relative aspect-[2/3] overflow-hidden rounded-2xl bg-secondary">
            <img
              src={program.image}
              alt={program.name}
              class="fade-image absolute inset-0 w-full h-full object-cover hover-zoom"
              loading="lazy"
              onload="this.classList.add('loaded')"
            />
          </div>
          <div class="py-6">
            <h3 class="text-lg font-medium leading-snug text-foreground">{program.name}</h3>
            <p class="mt-2 text-sm text-muted-foreground">{program.description}</p>
          </div>
        </div>
      ))}
    </div>

    <!-- Desktop: 3-column grid -->
    <div class="hidden md:grid md:grid-cols-3 gap-8 md:px-12 lg:px-20">
      {programs.map((program, index) => (
        <div class="reveal group" style={`transition-delay: ${index * 0.18}s`}>
          <div class="relative aspect-[2/3] overflow-hidden rounded-2xl bg-secondary reveal-clip" style={`transition-delay: ${0.15 + index * 0.18}s`}>
            <img
              src={program.image}
              alt={program.name}
              class="fade-image absolute inset-0 w-full h-full object-cover hover-zoom"
              loading="lazy"
              onload="this.classList.add('loaded')"
            />
          </div>
          <div class="py-6">
            <h3 class="text-lg font-medium leading-snug text-foreground">{program.name}</h3>
            <p class="mt-2 text-sm text-muted-foreground">{program.description}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
