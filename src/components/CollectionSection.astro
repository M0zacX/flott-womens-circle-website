---
const programs = [
  { name: "Wellness Education", description: "Hands-on workshops to help you care for your body and mind", image: "/images/flott-44.webp",
    icon: `<path d="M12 21c0-4-3-7-3-10s3-6 3-6 3 3 3 6-3 6-3 10z" /><path d="M12 21c-2-3-6-5-8-5 2-1 5 0 8 5z" /><path d="M12 21c2-3 6-5 8-5-2-1-5 0-8 5z" /><circle cx="12" cy="8" r="1.5" fill="currentColor" opacity="0.3" />` },
  { name: "Soft Skills Circles", description: "Build confidence, communication, and emotional intelligence in a supportive setting", image: "/images/flott-46.webp",
    icon: `<path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z" /><path d="M8 10h8" opacity="0.4" /><path d="M8 13h5" opacity="0.4" />` },
  { name: "Empowerment Gatherings", description: "Sessions designed to strengthen you mentally, socially, and financially", image: "/images/flott-48.webp",
    icon: `<path d="M12 2L2 7l10 5 10-5-10-5z" /><path d="M2 17l10 5 10-5" /><path d="M2 12l10 5 10-5" />` },
  { name: "Cultural Wellness", description: "Self-care rooted in tradition, adapted for the woman you're becoming", image: "/images/flott-50.webp",
    icon: `<circle cx="12" cy="12" r="10" /><path d="M12 2a14.5 14.5 0 0 0 0 20 14.5 14.5 0 0 0 0-20" /><path d="M2 12h20" /><path d="M12 2c2.5 3 4 6.5 4 10s-1.5 7-4 10" opacity="0.4" />` },
  { name: "Growth Conversations", description: "Honest conversations about identity, growth, and what it means to be a woman today", image: "/images/flott-42.webp",
    icon: `<path d="M12 20V4" /><path d="M12 4c-2-3-5-4-7-3" /><path d="M12 4c2-3 5-4 7-3" /><path d="M12 10c-1.5-2-4-3-6-2" /><path d="M12 10c1.5-2 4-3 6-2" /><path d="M12 15c-1-1.5-3-2-5-1.5" /><path d="M12 15c1-1.5 3-2 5-1.5" />` },
  { name: "Community Events", description: "Seasonal gatherings to celebrate, connect, and remind you that you're not alone", image: "/images/flott-54.webp",
    icon: `<path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2" /><circle cx="9" cy="7" r="4" /><path d="M23 21v-2a4 4 0 0 0-3-3.87" /><path d="M16 3.13a4 4 0 0 1 0 7.75" />` },
];
---

<section id="programs" class="programs-section bg-[#0f0906] relative overflow-hidden">
  <!-- Background images — one per program, revealed on hover -->
  {programs.map((program, i) => (
    <div
      class="program-bg absolute inset-0 will-change-[opacity]"
      data-bg-index={i}
      style="opacity: 0; transition: opacity 2s cubic-bezier(0.22, 1, 0.36, 1);"
    >
      <img
        src={program.image}
        alt=""
        class="absolute inset-0 w-full h-full object-cover"
        loading="lazy"
        style="transform: scale(1.08); transition: transform 10s cubic-bezier(0.22, 1, 0.36, 1);"
      />
      <div class="absolute inset-0 bg-[#0f0906]/60"></div>
    </div>
  ))}

  <div class="relative z-10 px-6 md:px-12 lg:px-20 py-14 md:py-20 lg:py-32">
    <!-- Header -->
    <div class="mb-10 md:mb-14 lg:mb-20">
      <p class="program-reveal text-xs uppercase tracking-[0.3em] text-white/25 mb-5" style="font-style: italic; transition-delay: 0s;">What We Offer</p>
      <h2 class="program-reveal text-3xl font-medium tracking-tight text-white md:text-4xl lg:text-5xl" style="transition-delay: 0.1s;">
        Our
        <span style="font-family: 'Playfair Display', serif; font-style: italic; font-weight: 500;">Programs</span>
      </h2>
    </div>

    <!-- Program list -->
    <div class="programs-list border-t border-white/[0.08]">
      {programs.map((program, index) => (
        <a
          href="/programs"
          class="program-row program-reveal group flex items-start md:items-center gap-5 md:gap-10 border-b border-white/[0.08] py-6 md:py-8 no-underline"
          data-row-index={index}
          style={`transition-delay: ${0.15 + index * 0.08}s;`}
        >
          <span
            class="program-number shrink-0 w-[36px] sm:w-[48px] md:w-[80px] lg:w-[100px] text-right text-2xl sm:text-3xl md:text-5xl lg:text-6xl font-light text-white/[0.1]"
            style="font-family: 'Playfair Display', serif; font-style: italic; transition: color 1.2s cubic-bezier(0.22, 1, 0.36, 1);"
          >
            {String(index + 1).padStart(2, '0')}
          </span>

          <div
            class="program-icon shrink-0 flex h-10 w-10 md:h-12 md:w-12 items-center justify-center rounded-full border border-white/10"
            style="opacity: 0; transform: scale(0.8); transition: opacity 1.2s cubic-bezier(0.22, 1, 0.36, 1), transform 1.2s cubic-bezier(0.22, 1, 0.36, 1);"
          >
            <svg class="h-5 w-5 md:h-6 md:w-6 text-[#c49298]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round">
              <Fragment set:html={program.icon} />
            </svg>
          </div>

          <div class="flex-1 min-w-0">
            <div
              class="program-content"
              style="transform: translateY(8px); transition: transform 1.2s cubic-bezier(0.22, 1, 0.36, 1);"
            >
              <h3
                class="program-title text-lg md:text-2xl lg:text-[2rem] text-white/40 font-medium tracking-tight leading-tight"
                style="transition: color 1.2s cubic-bezier(0.22, 1, 0.36, 1);"
              >
                {program.name}
              </h3>
              <p
                class="program-desc text-sm text-white/30 mt-2 max-w-lg"
                style="opacity: 0; transition: opacity 1.2s cubic-bezier(0.22, 1, 0.36, 1);"
              >{program.description}</p>
            </div>
          </div>

          <div
            class="program-arrow shrink-0 mt-1 md:mt-0 hidden md:block"
            style="opacity: 0; transform: translateX(-10px); transition: opacity 1s cubic-bezier(0.22, 1, 0.36, 1), transform 1s cubic-bezier(0.22, 1, 0.36, 1);"
          >
            <svg class="w-5 h-5 md:w-6 md:h-6 text-white/50" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M5 12h14" /><path d="m12 5 7 7-7 7" />
            </svg>
          </div>
        </a>
      ))}
    </div>

    <!-- CTA -->
    <div class="mt-8 md:mt-12 lg:mt-16 flex justify-center program-reveal" style="transition-delay: 0.7s;">
      <a
        href="/programs"
        class="inline-flex items-center gap-2 rounded-full border border-white/15 px-8 py-4 text-xs font-medium uppercase tracking-[0.15em] text-white/60 no-underline"
        style="transition: all 0.5s cubic-bezier(0.22, 1, 0.36, 1);"
        onmouseenter="this.style.backgroundColor='white'; this.style.color='#0f0906'; this.style.borderColor='white';"
        onmouseleave="this.style.backgroundColor='transparent'; this.style.color='rgba(255,255,255,0.6)'; this.style.borderColor='rgba(255,255,255,0.15)';"
      >
        Explore All Programs
        <svg class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
      </a>
    </div>
  </div>
</section>

<style>
  .program-reveal {
    opacity: 0;
    transform: translateY(24px);
    filter: blur(6px);
    will-change: opacity, transform, filter;
    transition:
      opacity 1.2s cubic-bezier(0.22, 1, 0.36, 1),
      transform 1.2s cubic-bezier(0.22, 1, 0.36, 1),
      filter 1.4s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .program-reveal.visible {
    opacity: 1;
    transform: translateY(0);
    filter: blur(0);
  }
</style>

<script>
  // Scroll reveal
  const programObs = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add("visible");
          programObs.unobserve(entry.target);
        }
      });
    },
    { threshold: 0.05 }
  );
  document.querySelectorAll(".program-reveal").forEach((el) => programObs.observe(el));

  // Program row interactions
  const section = document.querySelector(".programs-section");
  if (section) {
    const rows = section.querySelectorAll(".program-row");
    const bgs = section.querySelectorAll(".program-bg");
    let activeIndex = -1;

    const activateRow = (index) => {
      if (index === activeIndex) return;
      activeIndex = index;

      // Crossfade backgrounds
      bgs.forEach((bg, i) => {
        const img = bg.querySelector("img");
        if (i === index) {
          bg.style.opacity = "1";
          bg.style.zIndex = "1";
          if (img) img.style.transform = "scale(1)";
        } else {
          bg.style.opacity = "0";
          bg.style.zIndex = "0";
          if (img) img.style.transform = "scale(1.08)";
        }
      });

      // Highlight active row, dim others
      rows.forEach((r) => {
        const isActive = r.getAttribute("data-row-index") === String(index);
        const num = r.querySelector(".program-number");
        const icon = r.querySelector(".program-icon");
        const title = r.querySelector(".program-title");
        const content = r.querySelector(".program-content");
        const desc = r.querySelector(".program-desc");
        const arrow = r.querySelector(".program-arrow");

        if (num) num.style.color = isActive ? "rgba(255,255,255,0.6)" : "rgba(255,255,255,0.05)";
        if (icon) { icon.style.opacity = isActive ? "1" : "0"; icon.style.transform = isActive ? "scale(1)" : "scale(0.8)"; }
        if (title) title.style.color = isActive ? "rgba(255,255,255,1)" : "rgba(255,255,255,0.15)";
        if (content) content.style.transform = isActive ? "translateY(0)" : "translateY(8px)";
        if (desc) desc.style.opacity = isActive ? "1" : "0";
        if (arrow) {
          arrow.style.opacity = isActive ? "1" : "0";
          arrow.style.transform = isActive ? "translateX(0)" : "translateX(-10px)";
        }
      });
    };

    // Initialize first row as active
    activateRow(0);

    // Scroll-activated rows — works on all devices
    // On mobile/tablet: primary interaction (no hover available)
    // On desktop: keeps section in sync when user scrolls without hovering
    const rowScrollObs = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            const index = parseInt(entry.target.getAttribute("data-row-index") || "0");
            activateRow(index);
          }
        });
      },
      { rootMargin: "-25% 0px -50% 0px", threshold: 0 }
    );
    rows.forEach((row) => rowScrollObs.observe(row));

    // Hover interactions — only fires when a mouse is present
    // On touch-only devices, mouseenter never fires so this is a no-op
    let hoverTimer = null;
    rows.forEach((row) => {
      row.addEventListener("mouseenter", () => {
        clearTimeout(hoverTimer);
        const index = parseInt(row.getAttribute("data-row-index") || "0");
        hoverTimer = setTimeout(() => activateRow(index), 150);
      });
    });

    const list = section.querySelector(".programs-list");
    if (list) {
      list.addEventListener("mouseleave", () => {
        clearTimeout(hoverTimer);
      });
    }
  }
</script>
