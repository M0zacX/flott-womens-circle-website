---
const programs = [
  { name: "Wellness Education", description: "Hands-on workshops to help you care for your body and mind", image: "/images/flott-44.webp",
    icon: `<path d="M12 21c0-4-3-7-3-10s3-6 3-6 3 3 3 6-3 6-3 10z" /><path d="M12 21c-2-3-6-5-8-5 2-1 5 0 8 5z" /><path d="M12 21c2-3 6-5 8-5-2-1-5 0-8 5z" /><circle cx="12" cy="8" r="1.5" fill="currentColor" opacity="0.3" />` },
  { name: "Soft Skills Circles", description: "Build confidence, communication, and emotional intelligence in a supportive setting", image: "/images/flott-46.webp",
    icon: `<path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z" /><path d="M8 10h8" opacity="0.4" /><path d="M8 13h5" opacity="0.4" />` },
  { name: "Empowerment Gatherings", description: "Sessions designed to strengthen you mentally, socially, and financially", image: "/images/flott-48.webp",
    icon: `<path d="M12 2L2 7l10 5 10-5-10-5z" /><path d="M2 17l10 5 10-5" /><path d="M2 12l10 5 10-5" />` },
  { name: "Cultural Wellness", description: "Self-care rooted in tradition, adapted for the woman you're becoming", image: "/images/flott-50.webp",
    icon: `<circle cx="12" cy="12" r="10" /><path d="M12 2a14.5 14.5 0 0 0 0 20 14.5 14.5 0 0 0 0-20" /><path d="M2 12h20" /><path d="M12 2c2.5 3 4 6.5 4 10s-1.5 7-4 10" opacity="0.4" />` },
  { name: "Growth Conversations", description: "Honest conversations about identity, growth, and what it means to be a woman today", image: "/images/flott-42.webp",
    icon: `<path d="M12 20V4" /><path d="M12 4c-2-3-5-4-7-3" /><path d="M12 4c2-3 5-4 7-3" /><path d="M12 10c-1.5-2-4-3-6-2" /><path d="M12 10c1.5-2 4-3 6-2" /><path d="M12 15c-1-1.5-3-2-5-1.5" /><path d="M12 15c1-1.5 3-2 5-1.5" />` },
  { name: "Community Events", description: "Seasonal gatherings to celebrate, connect, and remind you that you're not alone", image: "/images/flott-54.webp",
    icon: `<path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2" /><circle cx="9" cy="7" r="4" /><path d="M23 21v-2a4 4 0 0 0-3-3.87" /><path d="M16 3.13a4 4 0 0 1 0 7.75" />` },
];
---

<section id="programs" class="bg-[#0f0906] relative overflow-hidden">
  <div class="px-6 md:px-12 lg:px-20 py-14 md:py-20 lg:py-32">
    <!-- Header -->
    <div class="reveal mb-10 md:mb-14 lg:mb-20">
      <p class="text-xs uppercase tracking-[0.3em] text-white/25 mb-5" style="font-style: italic">What We Offer</p>
      <h2 class="text-3xl font-medium tracking-tight text-white md:text-4xl lg:text-5xl">
        Our
        <span style="font-family: 'Playfair Display', serif; font-style: italic; font-weight: 500;">Programs</span>
      </h2>
    </div>

    <!-- Desktop: Expanding accordion strips -->
    <div class="reveal accordion-container hidden lg:flex gap-1.5" style="height: 75vh; min-height: 520px; max-height: 750px; transition-delay: 0.15s;">
      {programs.map((program, index) => (
        <a
          href="/programs"
          class="accordion-strip group relative overflow-hidden rounded-xl no-underline"
        >
          <!-- Background image -->
          <img
            src={program.image}
            alt={program.name}
            class="absolute inset-0 w-full h-full object-cover transition-transform duration-[1.2s] ease-[cubic-bezier(0.22,1,0.36,1)] group-hover:scale-110"
          />
          <!-- Gradient overlay — darkens more on hover -->
          <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/20 to-black/10 transition-opacity duration-700 group-hover:from-black/85" />

          <!-- Number watermark -->
          <span
            class="absolute top-5 left-5 text-[4rem] leading-none font-light text-white/[0.06] transition-all duration-700 ease-[cubic-bezier(0.22,1,0.36,1)] group-hover:text-white/[0.15]"
            style="font-family: 'Playfair Display', serif; font-style: italic;"
          >
            {String(index + 1).padStart(2, '0')}
          </span>

          <!-- Collapsed: vertical program name (centered) -->
          <div class="absolute inset-0 flex items-center justify-center transition-opacity duration-300 group-hover:opacity-0 pointer-events-none">
            <span
              class="text-white/40 text-[11px] font-medium uppercase tracking-[0.25em] whitespace-nowrap"
              style="writing-mode: vertical-rl;"
            >
              {program.name}
            </span>
          </div>

          <!-- Expanded: full content (appears on hover) -->
          <div class="absolute bottom-0 inset-x-0 p-6 translate-y-4 opacity-0 transition-all duration-700 ease-[cubic-bezier(0.22,1,0.36,1)] group-hover:translate-y-0 group-hover:opacity-100">
            <div class="flex items-center gap-3 mb-3">
              <div class="flex h-9 w-9 shrink-0 items-center justify-center rounded-full border border-white/20 bg-white/5 backdrop-blur-sm">
                <svg class="h-4 w-4 text-[#e8b4b8]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round">
                  <Fragment set:html={program.icon} />
                </svg>
              </div>
              <h3 class="text-white text-xl font-medium tracking-tight">{program.name}</h3>
            </div>
            <p class="text-white/50 text-sm leading-relaxed max-w-xs">{program.description}</p>
            <div class="mt-4 flex items-center gap-1.5 text-white/40 text-xs uppercase tracking-[0.15em]">
              <span>Learn more</span>
              <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
            </div>
          </div>
        </a>
      ))}
    </div>

    <!-- Mobile / Tablet: Card grid -->
    <div class="lg:hidden grid grid-cols-1 md:grid-cols-2 gap-4">
      {programs.map((program, index) => (
        <a
          href="/programs"
          class="reveal group relative overflow-hidden rounded-2xl no-underline"
          style={`transition-delay: ${index * 0.08}s`}
        >
          <div class="relative aspect-[4/3] overflow-hidden">
            <img
              src={program.image}
              alt={program.name}
              class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 ease-out group-hover:scale-105"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/20 to-transparent" />
            <div class="absolute bottom-0 inset-x-0 p-5">
              <div class="flex items-center gap-2.5 mb-2">
                <div class="flex h-8 w-8 shrink-0 items-center justify-center rounded-full border border-white/15 bg-white/5 backdrop-blur-sm">
                  <svg class="h-4 w-4 text-[#e8b4b8]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round">
                    <Fragment set:html={program.icon} />
                  </svg>
                </div>
                <span
                  class="text-white/15 text-2xl font-light"
                  style="font-family: 'Playfair Display', serif; font-style: italic;"
                >
                  {String(index + 1).padStart(2, '0')}
                </span>
              </div>
              <h3 class="text-white text-lg font-medium tracking-tight">{program.name}</h3>
              <p class="text-white/50 text-sm mt-1.5">{program.description}</p>
            </div>
          </div>
        </a>
      ))}
    </div>

    <!-- CTA -->
    <div class="reveal mt-10 md:mt-14 flex justify-center" style="transition-delay: 0.5s;">
      <a
        href="/programs"
        class="inline-flex items-center gap-2 rounded-full border border-white/15 px-8 py-4 text-xs font-medium uppercase tracking-[0.15em] text-white/60 no-underline transition-all duration-500 ease-[cubic-bezier(0.22,1,0.36,1)] hover:bg-white hover:text-[#0f0906] hover:border-white"
      >
        Explore All Programs
        <svg class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
      </a>
    </div>
  </div>
</section>

<style>
  .accordion-strip {
    flex: 1;
    transition: flex 0.8s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .accordion-strip:hover,
  .accordion-strip:focus-visible {
    flex: 5;
  }
  .accordion-strip:focus-visible {
    outline: 2px solid rgba(232, 180, 184, 0.5);
    outline-offset: -2px;
  }
</style>
