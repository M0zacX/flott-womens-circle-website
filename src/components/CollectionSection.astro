---
const accessories = [
  { id: 1, name: "Wireless Charging Stand", description: "Induction charging dock for effortless power", price: "$89", image: "/images/flott-44.jpeg" },
  { id: 2, name: "Protective Silicone Sleeve", description: "Textured grip sleeve for enhanced durability", price: "$45", image: "/images/flott-46.jpeg" },
  { id: 3, name: "Carbon Fiber Bike Mount", description: "Ultra-light mounting system for cycling", price: "$129", image: "/images/flott-48.jpeg" },
  { id: 4, name: "Premium Carry Strap", description: "Adjustable strap with quick-release clips", price: "$39", image: "/images/flott-50.jpeg" },
  { id: 5, name: "Carabiner Clip System", description: "Secure attachment for hands-free carrying", price: "$29", image: "/images/flott-52.jpeg" },
  { id: 6, name: "Bluetooth Speaker Base", description: "High-fidelity audio dock with grip stabilizers", price: "$149", image: "/images/flott-54.jpeg" },
];
---

<section id="accessories" class="bg-background">
  <div class="px-6 py-20 md:px-12 lg:px-20 md:py-10">
    <h2 class="text-3xl font-medium tracking-tight text-foreground md:text-4xl">Essential Accessories</h2>
  </div>

  <div class="pb-24">
    <!-- Mobile: horizontal scroll -->
    <div class="flex gap-6 overflow-x-auto px-6 pb-4 md:hidden snap-x snap-mandatory scrollbar-hide">
      {accessories.map((accessory) => (
        <div class="group flex-shrink-0 w-[75vw] snap-center">
          <div class="relative aspect-[2/3] overflow-hidden rounded-2xl bg-secondary">
            <img
              src={accessory.image}
              alt={accessory.name}
              class="fade-image absolute inset-0 w-full h-full object-cover transition-transform duration-300 group-hover:scale-105"
              loading="lazy"
              onload="this.classList.add('loaded')"
            />
          </div>
          <div class="py-6">
            <div class="flex items-start justify-between gap-4">
              <div class="flex-1">
                <h3 class="text-lg font-medium leading-snug text-foreground">{accessory.name}</h3>
                <p class="mt-2 text-sm text-muted-foreground">{accessory.description}</p>
              </div>
              <span class="text-lg font-medium text-foreground">{accessory.price}</span>
            </div>
          </div>
        </div>
      ))}
    </div>

    <!-- Desktop: 3-column grid -->
    <div class="hidden md:grid md:grid-cols-3 gap-8 md:px-12 lg:px-20">
      {accessories.map((accessory) => (
        <div class="group">
          <div class="relative aspect-[2/3] overflow-hidden rounded-2xl bg-secondary">
            <img
              src={accessory.image}
              alt={accessory.name}
              class="fade-image absolute inset-0 w-full h-full object-cover transition-transform duration-300 group-hover:scale-105"
              loading="lazy"
              onload="this.classList.add('loaded')"
            />
          </div>
          <div class="py-6">
            <div class="flex items-start justify-between gap-4">
              <div class="flex-1">
                <h3 class="text-lg font-medium leading-snug text-foreground">{accessory.name}</h3>
                <p class="mt-2 text-sm text-muted-foreground">{accessory.description}</p>
              </div>
              <span class="font-medium text-foreground text-2xl">{accessory.price}</span>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
