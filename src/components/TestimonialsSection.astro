    <path d="M218 270 Q202 282 190 280 Q204 276 218 270Z" />
    <path d="M210 244 Q190 240 178 228 Q194 238 210 244Z" />
    <path d="M225 215 Q208 204 202 186 Q216 200 225 215Z" />
    <!-- Ring 3: zigzag band -->
    <circle cx="250" cy="250" r="62" />
    <path d="M250 186 L254 180 L258 186 L262 180 L266 186 L270 180 L274 186" opacity="0.5" />
    <path d="M310 238 L316 234 L310 230 L316 226 L310 222" opacity="0.5" />
    <path d="M274 314 L270 320 L266 314 L262 320 L258 314 L254 320 L250 314" opacity="0.5" />
