    <path d="M250 160 L250 130" opacity="0.35" />
    <path d="M280 192 Q308 170 310 136 Q292 164 280 192Z" />
    <path d="M296 162 L306 142" opacity="0.35" />
    <path d="M306 228 Q340 224 360 200 Q334 218 306 228Z" />
    <path d="M338 216 L354 206" opacity="0.35" />
    <path d="M306 272 Q340 276 360 300 Q334 282 306 272Z" />
    <path d="M338 284 L354 294" opacity="0.35" />
    <path d="M280 308 Q308 330 310 364 Q292 336 280 308Z" />
    <path d="M296 338 L306 358" opacity="0.35" />
    <path d="M250 316 Q264 350 250 382 Q236 350 250 316Z" />
    <path d="M250 340 L250 370" opacity="0.35" />
    <path d="M220 308 Q192 330 190 364 Q208 336 220 308Z" />
    <path d="M204 338 L194 358" opacity="0.35" />
    <path d="M194 272 Q160 276 140 300 Q166 282 194 272Z" />
    <path d="M162 284 L146 294" opacity="0.35" />
    <path d="M194 228 Q160 224 140 200 Q166 218 194 228Z" />
    <path d="M162 216 L146 206" opacity="0.35" />
    <path d="M220 192 Q192 170 190 136 Q208 164 220 192Z" />
    <path d="M204 162 L194 142" opacity="0.35" />
    <path d="M270 196 Q294 178 302 154 Q286 174 270 196Z" />
    <path d="M230 304 Q206 322 198 346 Q214 326 230 304Z" />
    <!-- Ring 5: outer ring -->
    <circle cx="250" cy="250" r="105" />
    <!-- Scalloped arcs — 8 segments -->
    <path d="M250 142 Q290 130 330 148" fill="none" />
    <path d="M330 148 Q362 178 362 220" fill="none" />
    <path d="M362 280 Q362 322 330 352" fill="none" />
    <path d="M330 352 Q290 370 250 358" fill="none" />
    <path d="M250 358 Q210 370 170 352" fill="none" />
