    <!-- Tip dots -->
    <circle cx="250" cy="94" r="3" /><circle cx="406" cy="250" r="3" />
    <circle cx="250" cy="406" r="3" /><circle cx="94" cy="250" r="3" />
    <circle cx="338" cy="146" r="2" /><circle cx="338" cy="354" r="2" />
    <circle cx="162" cy="354" r="2" /><circle cx="162" cy="146" r="2" />
  </svg>

  <!-- Flowing Henna Paisley — bottom left, mobile visible -->
  <svg class="absolute bottom-16 -left-4 w-[130px] h-[185px] md:w-[180px] md:h-[260px] text-[#e8b4b8] opacity-[0.3] pointer-events-none" viewBox="0 0 300 420" fill="none" stroke="currentColor" stroke-width="1.1" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" style="transform: rotate(15deg)">
    <!-- Main paisley body -->
    <path d="M150 400 C100 350 40 280 40 190 C40 100 85 40 150 20 C215 40 260 100 260 190 C260 280 200 350 150 400Z" />
    <!-- Inner paisley -->
    <path d="M150 350 C115 315 75 265 75 195 C75 130 105 85 150 68 C195 85 225 130 225 195 C225 265 185 315 150 350Z" />
    <!-- Spiral center -->
    <path d="M150 210 C150 202 158 197 164 200 C170 203 168 214 162 216 C156 218 148 214 147 206 C146 198 152 192 162 192 C172 192 178 202 176 212 C174 222 162 228 154 226" />
    <!-- 6 petals -->
    <path d="M150 188 Q156 172 150 158 Q144 172 150 188Z" />
    <path d="M166 200 Q180 194 188 182 Q176 192 166 200Z" />
    <path d="M166 218 Q180 224 188 236 Q176 226 166 218Z" />
    <path d="M150 230 Q156 246 150 260 Q144 246 150 230Z" />
    <path d="M134 218 Q120 224 112 236 Q124 226 134 218Z" />
    <path d="M134 200 Q120 194 112 182 Q124 192 134 200Z" />
    <!-- Dots -->
    <circle cx="150" cy="152" r="2.5" /><circle cx="192" cy="178" r="2.5" /><circle cx="192" cy="240" r="2.5" />
    <circle cx="150" cy="264" r="2.5" /><circle cx="108" cy="240" r="2.5" /><circle cx="108" cy="178" r="2.5" />
    <!-- Top curl -->
    <path d="M150 20 C172 12 182 22 178 38 C174 52 158 48 162 34" />
    <circle cx="150" cy="12" r="2.5" />
  </svg>

  <div class="px-6 py-14 md:px-12 md:py-20 lg:px-20 lg:py-40">
    <ScrollRevealText
      client:visible
      text="Empowerment starts with awareness. Growth happens fastest in safe spaces. And wellness isn't separate from empowerment — it is empowerment."
      className="mx-auto max-w-5xl text-2xl leading-relaxed md:text-3xl lg:text-[2.5rem] lg:leading-snug"
      accentWords={["awareness", "empowerment"]}
    />
  </div>

  <div class="relative aspect-[16/9] sm:aspect-[21/9] lg:aspect-[32/9] w-full reveal">
    <img src="/images/flott-footer-img.webp" alt="Flott Women's Circle community" class="absolute inset-0 w-full h-full object-cover" />
    <div class="absolute inset-0 bg-gradient-to-t from-background via-background/40 to-black/30"></div>
    <div class="absolute inset-0 flex items-end px-6 pb-6 sm:px-8 sm:pb-8 md:px-14 md:pb-12 lg:px-20 lg:pb-16">
      <div class="cta-words" style="text-indent: -0.04em;">
        <h2 class="text-3xl sm:text-4xl md:text-6xl lg:text-7xl xl:text-8xl font-medium leading-[1.05] tracking-tight">
          <span class="cta-w" style="transition-delay: 0s;">When</span>{" "}
          <span class="cta-w" style="transition-delay: 0.15s;">Women</span>{" "}
          <span class="cta-w" style="transition-delay: 0.3s;">Rise,</span><br/>
          <span class="cta-w" style="transition-delay: 0.45s;">Everything</span>{" "}
          <span class="cta-w" style="transition-delay: 0.65s; font-family: 'Playfair Display', serif; font-style: italic; font-weight: 500;">Changes.</span>
        </h2>
        <p class="cta-sub mt-3 md:mt-5 text-xs md:text-sm font-normal tracking-[0.2em] uppercase">Flott Women's Circle</p>
      </div>
    </div>
  </div>

  <script>
    const ctaObs = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add("visible");
            ctaObs.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.05 }
    );
    document.querySelectorAll(".cta-words").forEach((el) => ctaObs.observe(el));
  </script>
</section>

<style>
  .cta-w {
    color: transparent;
    filter: blur(8px);
    will-change: color, filter;
    transition:
      color 1.2s cubic-bezier(0.22, 1, 0.36, 1),
      filter 1.6s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .cta-words.visible .cta-w {
    color: #0F0906;
    filter: blur(0);
  }
  .cta-sub {
    color: transparent;
    filter: blur(6px);
    will-change: color, filter;
    transition:
      color 1.2s cubic-bezier(0.22, 1, 0.36, 1) 0.9s,
      filter 1.6s cubic-bezier(0.22, 1, 0.36, 1) 0.9s;
  }
  .cta-words.visible .cta-sub {
    color: rgb(15 9 6 / 0.6);
    filter: blur(0);
  }
</style>
