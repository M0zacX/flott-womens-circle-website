---
import Layout from "../layouts/Layout.astro";
import { Header } from "../components/Header";
import FooterSection from "../components/FooterSection.astro";

const founder = {
  name: "Safiya Umar",
  role: "Founder & Group CEO",
  description: "Safiya built Flott Women's Circle from a simple belief: women deserve spaces that are grounded, intentional, and real. Spaces to nurture wellbeing, build confidence, and grow alongside other women — rooted in culture and care.",
  image: "/images/team/safiya-umar.png",
};

const leads = [
  {
    name: "Zulaihat Adamu Barde",
    role: "Circle Lead, Abuja",
    focus: "Holds space for wellness education, modern routines, and mindful living.",
    image: "/images/team/zulaihat-barde.png",
  },
  {
    name: "Maimuna Adejoh Yakubu",
    role: "Circle Lead, Kaduna",
    focus: "Holds space for cultural wellness education and soft skills for self-expression.",
    image: "/images/team/maimuna-yakubu.png",
  },
  {
    name: "Rita Ogbeagu",
    role: "Circle Lead, Port Harcourt",
    focus: "Holds space for body care education, confidence building, and self-value.",
    image: "/images/team/rita-ogbeagu.png",
  },
  {
    name: "Jane Oge Onyeansui",
    role: "Circle Lead, Enugu",
    focus: "Holds space for emotional intelligence, balance, and personal renewal.",
    image: "/images/team/jane-onyeansui.png",
  },
  {
    name: "Fatima Bintu Abubakar",
    role: "Circle Lead, Ilorin",
    focus: "Holds space for family-centred wellbeing, emotional grounding, and financial awareness.",
    image: "/images/team/fatima-abubakar.png",
  },
];
---

<Layout title="Team - Flott Women's Circle">
  <main class="min-h-screen bg-background overflow-x-clip">
    <Header client:load innerPage={true} currentPath="/team" />

    <!-- Hero -->
    <section class="relative pt-32 pb-16 md:pt-40 md:pb-24 px-6 md:px-12 lg:px-20 overflow-hidden">
      <!-- Vine SVG -->
      <svg class="absolute top-20 -right-8 w-[160px] h-[240px] md:w-[220px] md:h-[330px] text-[#e8b4b8] opacity-[0.3] pointer-events-none hidden md:block" viewBox="0 0 300 450" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M150 440 C150 400 120 370 130 320 C140 270 100 250 115 200 C130 150 160 160 150 110 C142 70 120 50 140 20" />
        <circle cx="140" cy="20" r="5" /><circle cx="140" cy="20" r="12" />
        <path d="M140 5 Q146 -8 140 -18 Q134 -8 140 5Z" />
        <path d="M155 14 Q168 8 174 -2 Q162 6 155 14Z" />
        <path d="M125 18 Q112 12 106 0 Q118 8 125 18Z" />
        <circle cx="115" cy="200" r="4" /><circle cx="115" cy="200" r="10" />
        <path d="M115 186 Q120 174 115 164 Q110 174 115 186Z" />
        <path d="M128 194 Q140 188 146 178 Q134 186 128 194Z" />
        <path d="M102 194 Q90 188 84 178 Q96 186 102 194Z" />
        <path d="M130 320 C105 305 90 312 86 298 C82 284 100 278 130 300" />
        <path d="M130 320 C155 305 170 312 174 298 C178 284 160 278 130 300" />
      </svg>

      <p class="blur-words text-xs uppercase tracking-[0.3em] text-muted-foreground mb-4" style="font-style: italic">Circle Leadership</p>
      <h1 class="word-blur-group text-4xl font-medium tracking-tight text-foreground md:text-5xl lg:text-6xl max-w-3xl">
        <span class="word-blur" style="transition-delay: 0.05s">Women</span>
        <span class="word-blur" style="transition-delay: 0.12s">Who</span>
        <span class="word-blur" style="transition-delay: 0.2s">Hold</span>
        <span class="word-blur" style="transition-delay: 0.35s; font-family: 'Playfair Display', serif; font-style: italic; font-weight: 500;">Space</span>
      </h1>
      <p class="blur-words mt-6 text-base text-muted-foreground max-w-xl leading-relaxed">
        Led by women who show up with care, intention, and heart.
      </p>
    </section>

    <!-- Founder -->
    <section class="px-6 pb-16 md:px-12 md:pb-24 lg:px-20 lg:pb-28">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 lg:gap-16 items-center max-w-5xl mx-auto">
        <div class="reveal-clip relative aspect-[3/4] overflow-hidden rounded-2xl" style="transition-delay: 0.1s">
          <img src={founder.image} alt={founder.name} class="fade-image absolute inset-0 w-full h-full object-cover" loading="lazy" onload="this.classList.add('loaded')" />
        </div>
        <div>
          <p class="reveal text-xs uppercase tracking-[0.3em] text-primary mb-3" style="font-style: italic; transition-delay: 0s">Founder</p>
          <h2 class="reveal text-3xl md:text-4xl font-medium tracking-tight text-foreground" style="transition-delay: 0.08s">{founder.name}</h2>
          <p class="reveal text-sm text-muted-foreground mt-1" style="transition-delay: 0.12s">{founder.role}</p>
          <div class="h-px w-12 bg-primary mt-6 mb-6 reveal" style="transition-delay: 0.16s"></div>
          <p class="reveal text-sm leading-relaxed text-muted-foreground" style="transition-delay: 0.2s">{founder.description}</p>
        </div>
      </div>
    </section>

    <!-- Circle Leads -->
    <section class="px-6 pb-20 md:px-12 md:pb-28 lg:px-20 lg:pb-36">
      <div class="max-w-5xl mx-auto">
        <p class="blur-words text-xs uppercase tracking-[0.3em] text-muted-foreground mb-4" style="font-style: italic">Circle Leads</p>
        <h2 class="word-blur-group text-2xl font-medium tracking-tight text-foreground md:text-3xl mb-12">
          <span class="word-blur" style="transition-delay: 0.05s">Our</span>
          <span class="word-blur" style="transition-delay: 0.15s; font-family: 'Playfair Display', serif; font-style: italic; font-weight: 500;">Leadership</span>
        </h2>

        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 lg:gap-8">
          {leads.map((lead, i) => (
            <div class="reveal group" style={`transition-delay: ${i * 0.1}s`}>
              <div class="relative aspect-[3/4] overflow-hidden rounded-2xl reveal-clip" style={`transition-delay: ${0.05 + i * 0.1}s`}>
                <img
                  src={lead.image}
                  alt={lead.name}
                  class="fade-image absolute inset-0 w-full h-full object-cover hover-zoom"
                  loading="lazy"
                  onload="this.classList.add('loaded')"
                />
                <div class="absolute inset-x-0 bottom-0 p-4">
                  <div class="backdrop-blur-md rounded-xl px-4 py-3" style="background: rgba(255, 255, 255, 0.15); border: 1px solid rgba(255, 255, 255, 0.1)">
                    <p class="text-white text-sm font-medium">{lead.name}</p>
                    <p class="text-white/60 text-xs mt-0.5">{lead.role}</p>
                  </div>
                </div>
              </div>
              <p class="mt-4 text-xs leading-relaxed text-muted-foreground">{lead.focus}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <FooterSection />
  </main>
</Layout>
