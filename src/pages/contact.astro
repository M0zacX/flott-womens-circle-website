---
import Layout from "../layouts/Layout.astro";
import { Header } from "../components/Header";
import FooterSection from "../components/FooterSection.astro";
import { ScrollRevealText } from "../components/ScrollRevealText";

const circles = [
  {
    city: "Abuja",
    address: "No. 6 Ubiaja Crescent, Garki 2",
    instagram: "@flott_beauty",
    instagramUrl: "https://instagram.com/flott_beauty",
    offset: 0,
  },
  {
    city: "Kaduna",
    address: "6 Link Close, GRA",
    instagram: "@flott_beautykd",
    instagramUrl: "https://instagram.com/flott_beautykd",
    offset: -32,
  },
  {
    city: "Port Harcourt",
    address: "No. 6 Onne Street, GRA",
    instagram: "@flott_beautyph",
    instagramUrl: "https://instagram.com/flott_beautyph",
    offset: 14,
  },
  {
    city: "Enugu",
    address: "45 Isi Uzo Street",
    instagram: "@flott_beautyen",
    instagramUrl: "https://instagram.com/flott_beautyen",
    offset: -22,
  },
  {
    city: "Ilorin",
    address: "",
    instagram: "",
    instagramUrl: "",
    offset: 6,
  },
];
---

<Layout title="Contact - Flott Women's Circle">
  <main class="min-h-screen bg-background overflow-x-clip">
    <Header client:load innerPage={true} currentPath="/contact" />

    <!-- Full-width editorial image -->
    <div class="relative aspect-[3/1] sm:aspect-[4/1] lg:aspect-[5/1] w-full reveal">
      <img src="/images/contact-header.webp" alt="Flott Women's Circle" class="absolute inset-0 w-full h-full object-cover object-center" />
      <div class="absolute inset-0 bg-gradient-to-t from-background via-transparent to-transparent"></div>
    </div>

    <!-- Contact Info — Split Layout -->
    <section class="px-6 py-10 md:px-12 md:py-14 lg:px-20 lg:py-16">
      <div class="max-w-4xl mx-auto">
        <div class="md:grid md:grid-cols-[1fr_1px_1fr] md:gap-12 lg:gap-16 items-start">
          <!-- Email -->
          <div class="reveal" style="transition-delay: 0s;">
            <p class="blur-words text-xs uppercase tracking-[0.3em] text-muted-foreground mb-5" style="font-style: italic">Email Us</p>
            <a
              href="mailto:info@flottwomen.com"
              class="text-xl md:text-2xl font-medium text-foreground tracking-tight no-underline transition-colors duration-400 ease-[cubic-bezier(0.22,1,0.36,1)] hover:text-primary"
            >
              info@flottwomen.com
            </a>
            <p class="mt-4 text-sm text-muted-foreground leading-relaxed max-w-sm">
              Questions about programs, partnerships, or joining a Circle? We'd love to hear from you.
            </p>
          </div>

          <!-- Divider -->
          <div class="hidden md:block bg-border self-stretch"></div>
          <hr class="md:hidden my-10 border-border" />

          <!-- Social -->
          <div class="reveal" style="transition-delay: 0.15s;">
            <p class="blur-words text-xs uppercase tracking-[0.3em] text-muted-foreground mb-5" style="font-style: italic">Follow Us</p>
            <a
              href="https://instagram.com/flott_beauty"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 text-xl md:text-2xl font-medium text-foreground tracking-tight no-underline transition-colors duration-400 ease-[cubic-bezier(0.22,1,0.36,1)] hover:text-primary"
            >
              <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
              @flott_beauty
            </a>
            <div class="mt-5 flex flex-wrap gap-2">
              {circles.filter(c => c.instagramUrl).map(c => (
                <a
                  href={c.instagramUrl}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="text-[11px] text-muted-foreground border border-border rounded-full px-3 py-1.5 no-underline transition-all duration-400 ease-[cubic-bezier(0.22,1,0.36,1)] hover:text-foreground hover:border-foreground"
                >
                  {c.city}
                </a>
              ))}
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- 5 Circle Locations — SVG Circle Network -->
    <section class="bg-background relative overflow-hidden py-12 md:py-16 lg:py-20">

      <!-- Decorative paisley — top right -->
      <svg class="absolute top-20 right-4 w-[100px] h-[140px] md:w-[130px] md:h-[185px] text-[#e8b4b8] opacity-[0.18] pointer-events-none" viewBox="0 0 300 420" fill="none" stroke="currentColor" stroke-width="0.9" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M150 400 C100 350 40 280 40 190 C40 100 85 40 150 20 C215 40 260 100 260 190 C260 280 200 350 150 400Z" />
        <path d="M150 350 C115 315 75 265 75 195 C75 130 105 85 150 68 C195 85 225 130 225 195 C225 265 185 315 150 350Z" />
        <path d="M150 210 C150 202 158 197 164 200 C170 203 168 214 162 216 C156 218 148 214 147 206" />
      </svg>

      <!-- Decorative floral — bottom left -->
      <svg class="absolute bottom-12 left-4 w-[80px] h-[80px] md:w-[120px] md:h-[120px] text-[#e8b4b8] opacity-[0.15] pointer-events-none" viewBox="0 0 200 200" fill="none" stroke="currentColor" stroke-width="0.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <circle cx="100" cy="100" r="4" />
        <path d="M100 92 Q104 80 100 68 Q96 80 100 92Z" />
        <path d="M108 96 Q120 92 128 82 Q118 90 108 96Z" />
        <path d="M108 106 Q120 110 128 120 Q118 112 108 106Z" />
        <path d="M100 110 Q104 122 100 134 Q96 122 100 110Z" />
        <path d="M92 106 Q80 110 72 120 Q82 112 92 106Z" />
        <path d="M92 96 Q80 92 72 82 Q82 90 92 96Z" />
        <circle cx="100" cy="100" r="28" />
        <circle cx="100" cy="100" r="50" />
      </svg>

      <!-- Section header -->
      <div class="px-6 md:px-12 lg:px-20 mb-10 md:mb-12 lg:mb-16 relative z-10">
        <p class="contact-reveal text-xs uppercase tracking-[0.3em] text-muted-foreground mb-4" style="font-style: italic; transition-delay: 0s;">Our Circles</p>
        <h2 class="contact-reveal text-3xl font-medium tracking-tight text-foreground md:text-4xl lg:text-5xl" style="transition-delay: 0.1s;">
          5 Cities,
          <span style="font-family: 'Playfair Display', serif; font-style: italic; font-weight: 500;">One Community</span>
        </h2>
        <p class="contact-reveal mt-4 text-sm text-muted-foreground max-w-md leading-relaxed" style="transition-delay: 0.2s;">
          Find your Circle. DM us on Instagram or visit any of our locations across Nigeria.
        </p>
      </div>

      <!-- 5 Circles — staggered row -->
      <div class="circles-row relative px-6 md:px-12 lg:px-16 xl:px-20">
        <div class="flex flex-wrap justify-center gap-8 md:gap-10 lg:flex-nowrap lg:justify-between lg:gap-0">
          {circles.map((circle, i) => (
            <a
              href={circle.instagramUrl || undefined}
              target={circle.instagramUrl ? "_blank" : undefined}
              rel={circle.instagramUrl ? "noopener noreferrer" : undefined}
              class={`circle-item contact-reveal flex flex-col items-center w-[42%] md:w-[28%] lg:w-auto lg:flex-1 no-underline ${circle.instagramUrl ? 'cursor-pointer' : 'cursor-default'}`}
              style={`transition-delay: ${0.15 + i * 0.08}s;`}
            >
              <div class="flex flex-col items-center" style={`--stagger: ${circle.offset}px`}>

                <!-- The circle -->
                <div class="circle-ring relative w-[140px] h-[140px] md:w-[160px] md:h-[160px] lg:w-[170px] lg:h-[170px] xl:w-[200px] xl:h-[200px] rounded-full border border-foreground/[0.1] flex flex-col items-center justify-center">

                  <!-- Inner dashed ring -->
                  <div class="absolute inset-3 md:inset-3.5 rounded-full border border-dashed border-foreground/[0.04]"></div>

                  <!-- Perimeter dots — 4 cardinal points -->
                  <div class="absolute -top-[3px] left-1/2 -translate-x-1/2 w-1.5 h-1.5 rounded-full bg-foreground/[0.08]"></div>
                  <div class="absolute -bottom-[3px] left-1/2 -translate-x-1/2 w-1.5 h-1.5 rounded-full bg-foreground/[0.08]"></div>
                  <div class="absolute top-1/2 -left-[3px] -translate-y-1/2 w-1.5 h-1.5 rounded-full bg-foreground/[0.08]"></div>
                  <div class="absolute top-1/2 -right-[3px] -translate-y-1/2 w-1.5 h-1.5 rounded-full bg-foreground/[0.08]"></div>

                  <!-- Number -->
                  <span
                    class="circle-item-num text-2xl md:text-3xl xl:text-4xl font-light text-foreground/[0.07]"
                    style="font-family: 'Playfair Display', serif; font-style: italic;"
                  >
                    {String(i + 1).padStart(2, '0')}
                  </span>

                  <!-- City name -->
                  <h3 class="circle-item-city mt-1 text-sm md:text-base xl:text-lg font-medium text-foreground/40 tracking-tight">
                    {circle.city}
                  </h3>
                </div>

                <!-- Details below circle -->
                <div class="circle-item-details mt-5 text-center min-h-[52px] flex flex-col justify-start">
                  {circle.address ? (
                    <>
                      <p class="text-[11px] text-muted-foreground leading-relaxed">{circle.address}</p>
                      <p class="mt-1.5 text-[11px] text-[#c49298] tracking-wide">{circle.instagram}</p>
                    </>
                  ) : (
                    <p class="text-[11px] text-muted-foreground italic">Coming soon</p>
                  )}
                </div>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- Philosophy Quote + CTA -->
    <section class="bg-background relative overflow-hidden">
      <svg class="absolute -top-8 -right-12 w-[140px] h-[140px] md:w-[200px] md:h-[200px] text-[#e8b4b8] opacity-[0.25] pointer-events-none" viewBox="0 0 400 400" fill="none" stroke="currentColor" stroke-width="0.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <circle cx="200" cy="200" r="30" />
        <circle cx="200" cy="200" r="50" />
        <path d="M200 148 Q206 134 200 120 Q194 134 200 148Z" />
        <path d="M252 194 Q266 188 278 178 Q264 190 252 194Z" />
        <path d="M200 252 Q206 266 200 278 Q194 266 200 252Z" />
        <path d="M148 194 Q134 188 122 178 Q136 190 148 194Z" />
        <circle cx="200" cy="200" r="80" />
      </svg>

      <div class="px-6 py-8 md:px-12 md:py-10 lg:px-20 lg:py-14">
        <ScrollRevealText
          client:visible
          text="Every Circle starts with one step. Yours is here."
          className="mx-auto max-w-4xl text-2xl leading-relaxed md:text-3xl lg:text-[2.3rem] lg:leading-snug"
          accentWords={["Circle", "here"]}
        />
      </div>

      <div class="relative aspect-[16/9] sm:aspect-[21/9] lg:aspect-[32/9] w-full reveal">
        <img src="/images/flott-footer-img.webp" alt="Flott Women's Circle community" class="absolute inset-0 w-full h-full object-cover" />
        <div class="absolute inset-0 bg-gradient-to-t from-background via-background/40 to-black/30"></div>
        <div class="absolute inset-0 flex items-end px-6 pb-6 sm:px-8 sm:pb-8 md:px-14 md:pb-12 lg:px-20 lg:pb-16">
          <div class="contact-cta-words" style="text-indent: -0.04em;">
            <h2 class="text-3xl sm:text-4xl md:text-6xl lg:text-7xl xl:text-8xl font-medium leading-[1.05] tracking-tight">
              <span class="contact-cta-w" style="transition-delay: 0s;">Come</span>{" "}
              <span class="contact-cta-w" style="transition-delay: 0.15s;">As</span>{" "}
              <span class="contact-cta-w" style="transition-delay: 0.3s;">You</span>{" "}
              <span class="contact-cta-w" style="transition-delay: 0.45s; font-family: 'Playfair Display', serif; font-style: italic; font-weight: 500;">Are.</span>
            </h2>
            <p class="contact-cta-sub mt-3 md:mt-5 text-xs md:text-sm font-normal tracking-[0.2em] uppercase">Flott Women's Circle</p>
          </div>
        </div>
      </div>
    </section>

    <FooterSection />
  </main>
</Layout>

<style>
  .contact-reveal {
    opacity: 0;
    transform: translateY(24px);
    filter: blur(6px);
    will-change: opacity, transform, filter;
    transition:
      opacity 1.2s cubic-bezier(0.22, 1, 0.36, 1),
      transform 1.2s cubic-bezier(0.22, 1, 0.36, 1),
      filter 1.4s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .contact-reveal.visible {
    opacity: 1;
    transform: translateY(0);
    filter: blur(0);
  }

  /* Circle interactions — CSS only */
  .circle-item {
    transition: opacity 0.8s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .circle-ring {
    transition:
      border-color 0.8s cubic-bezier(0.22, 1, 0.36, 1),
      box-shadow 0.8s cubic-bezier(0.22, 1, 0.36, 1),
      background 0.8s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .circle-item-num {
    transition: color 0.8s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .circle-item-city {
    transition: color 0.8s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .circle-item-details * {
    transition: color 0.8s cubic-bezier(0.22, 1, 0.36, 1);
  }

  /* Hover: dim siblings, brighten active */
  .circles-row:hover .circle-item {
    opacity: 0.3;
  }
  .circles-row:hover .circle-item:hover {
    opacity: 1;
  }

  /* Active circle glow */
  .circle-item:hover .circle-ring {
    border-color: rgba(196, 146, 152, 0.45);
    box-shadow: 0 0 60px rgba(196, 146, 152, 0.12), inset 0 0 30px rgba(196, 146, 152, 0.05);
    background: rgba(196, 146, 152, 0.04);
  }
  .circle-item:hover .circle-item-num {
    color: rgba(15, 9, 6, 0.2) !important;
  }
  .circle-item:hover .circle-item-city {
    color: rgba(15, 9, 6, 1) !important;
  }
  .circle-item:hover .circle-item-details p {
    color: rgba(15, 9, 6, 0.6);
  }
  .circle-item:hover .circle-item-details p:last-child {
    color: #c49298;
  }

  /* Vertical stagger — desktop only */
  @media (min-width: 1024px) {
    .circle-item > div {
      transform: translateY(var(--stagger, 0));
    }
  }

  .contact-cta-w {
    color: transparent;
    filter: blur(8px);
    will-change: color, filter;
    transition:
      color 1.2s cubic-bezier(0.22, 1, 0.36, 1),
      filter 1.6s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .contact-cta-words.visible .contact-cta-w {
    color: #0F0906;
    filter: blur(0);
  }
  .contact-cta-sub {
    color: transparent;
    filter: blur(6px);
    will-change: color, filter;
    transition:
      color 1.2s cubic-bezier(0.22, 1, 0.36, 1) 0.9s,
      filter 1.6s cubic-bezier(0.22, 1, 0.36, 1) 0.9s;
  }
  .contact-cta-words.visible .contact-cta-sub {
    color: rgb(15 9 6 / 0.6);
    filter: blur(0);
  }
</style>

<script>
  // Scroll reveal
  const contactObs = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add("visible");
          contactObs.unobserve(entry.target);
        }
      });
    },
    { threshold: 0.05 }
  );
  document.querySelectorAll(".contact-reveal").forEach((el) => contactObs.observe(el));

  // CTA word reveal
  const ctaContactObs = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add("visible");
          ctaContactObs.unobserve(entry.target);
        }
      });
    },
    { threshold: 0.05 }
  );
  document.querySelectorAll(".contact-cta-words").forEach((el) => ctaContactObs.observe(el));
</script>
