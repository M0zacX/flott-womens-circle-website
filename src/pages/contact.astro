---
import Layout from "../layouts/Layout.astro";
import { Header } from "../components/Header";
import FooterSection from "../components/FooterSection.astro";
import { ScrollRevealText } from "../components/ScrollRevealText";

const circles = [
  {
    city: "Abuja",
    address: "No. 6 Ubiaja Crescent, Garki 2",
    instagram: "@flott_beauty",
    instagramUrl: "https://instagram.com/flott_beauty",
    offset: 0,
  },
  {
    city: "Kaduna",
    address: "6 Link Close, GRA",
    instagram: "@flott_beautykd",
    instagramUrl: "https://instagram.com/flott_beautykd",
    offset: -32,
  },
  {
    city: "Port Harcourt",
    address: "No. 6 Onne Street, GRA",
    instagram: "@flott_beautyph",
    instagramUrl: "https://instagram.com/flott_beautyph",
    offset: 14,
  },
  {
    city: "Enugu",
    address: "45 Isi Uzo Street",
    instagram: "@flott_beautyen",
    instagramUrl: "https://instagram.com/flott_beautyen",
    offset: -22,
  },
  {
    city: "Ilorin",
    address: "",
    instagram: "",
    instagramUrl: "",
    offset: 6,
  },
];
---

<Layout title="Contact - Flott Women's Circle">
  <main class="min-h-screen bg-background overflow-x-clip">
    <Header client:load innerPage={true} currentPath="/contact" />

    <!-- Full-width editorial image -->
    <div class="relative aspect-[3/1] sm:aspect-[4/1] lg:aspect-[5/1] w-full reveal">
      <img src="/images/contact-header.webp" alt="Flott Women's Circle" class="absolute inset-0 w-full h-full object-cover object-center" />
      <div class="absolute inset-0 bg-gradient-to-t from-background via-transparent to-transparent"></div>
    </div>

    <!-- Contact Info — Split Layout -->
    <section class="px-6 py-10 md:px-12 md:py-14 lg:px-20 lg:py-16">
      <div class="max-w-4xl mx-auto">
        <div class="md:grid md:grid-cols-[1fr_1px_1fr] md:gap-12 lg:gap-16 items-start">
          <!-- Email -->
          <div class="reveal" style="transition-delay: 0s;">
            <p class="blur-words text-xs uppercase tracking-[0.3em] text-muted-foreground mb-5" style="font-style: italic">Email Us</p>
            <a
              href="mailto:info@flottwomen.com"
              class="text-xl md:text-2xl font-medium text-foreground tracking-tight no-underline transition-colors duration-400 ease-[cubic-bezier(0.22,1,0.36,1)] hover:text-primary"
            >
              info@flottwomen.com
            </a>
            <p class="mt-4 text-sm text-muted-foreground leading-relaxed max-w-sm">
              Questions about programs, partnerships, or joining a Circle? We'd love to hear from you.
            </p>
          </div>

          <!-- Divider -->
          <div class="hidden md:block bg-border self-stretch"></div>
          <hr class="md:hidden my-10 border-border" />

          <!-- Social -->
          <div class="reveal" style="transition-delay: 0.15s;">
            <p class="blur-words text-xs uppercase tracking-[0.3em] text-muted-foreground mb-5" style="font-style: italic">Follow Us</p>
            <a
              href="https://instagram.com/flott_beauty"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 text-xl md:text-2xl font-medium text-foreground tracking-tight no-underline transition-colors duration-400 ease-[cubic-bezier(0.22,1,0.36,1)] hover:text-primary"
            >
              <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
              @flott_beauty
            </a>
            <div class="mt-5 flex flex-wrap gap-2">
              {circles.filter(c => c.instagramUrl).map(c => (
                <a
                  href={c.instagramUrl}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="text-[11px] text-muted-foreground border border-border rounded-full px-3 py-1.5 no-underline transition-all duration-400 ease-[cubic-bezier(0.22,1,0.36,1)] hover:text-foreground hover:border-foreground"
                >
                  {c.city}
                </a>
              ))}
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Contact Form — Editorial Split -->
    <section class="bg-background relative overflow-hidden">
      <!-- Thin top border -->
      <div class="mx-6 md:mx-12 lg:mx-20 border-t border-border"></div>

      <!-- Decorative floral — behind left column -->
      <svg class="absolute top-24 left-6 w-[160px] h-[220px] md:w-[200px] md:h-[280px] text-[#e8b4b8] opacity-[0.12] pointer-events-none hidden md:block" viewBox="0 0 300 420" fill="none" stroke="currentColor" stroke-width="0.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M150 400 C100 350 40 280 40 190 C40 100 85 40 150 20 C215 40 260 100 260 190 C260 280 200 350 150 400Z" />
        <path d="M150 350 C115 315 75 265 75 195 C75 130 105 85 150 68 C195 85 225 130 225 195 C225 265 185 315 150 350Z" />
        <path d="M150 210 C150 202 158 197 164 200 C170 203 168 214 162 216 C156 218 148 214 147 206 C146 198 152 192 162 192 C172 192 178 202 176 212 C174 222 162 228 154 226" />
        <path d="M150 188 Q156 172 150 158 Q144 172 150 188Z" />
        <path d="M166 200 Q180 194 188 182 Q176 192 166 200Z" />
        <path d="M166 218 Q180 224 188 236 Q176 226 166 218Z" />
        <path d="M150 230 Q156 246 150 260 Q144 246 150 230Z" />
        <path d="M134 218 Q120 224 112 236 Q124 226 134 218Z" />
        <path d="M134 200 Q120 194 112 182 Q124 192 134 200Z" />
        <circle cx="150" cy="152" r="2.5" /><circle cx="192" cy="178" r="2.5" /><circle cx="192" cy="240" r="2.5" />
        <circle cx="150" cy="264" r="2.5" /><circle cx="108" cy="240" r="2.5" /><circle cx="108" cy="178" r="2.5" />
      </svg>

      <div class="px-6 py-10 md:px-12 md:py-14 lg:px-20 lg:py-20">
        <div class="max-w-5xl mx-auto">
          <div class="flex flex-col gap-10 md:flex-row md:gap-16 lg:gap-24">

            <!-- Left column — heading + copy -->
            <div class="md:w-[38%] lg:w-[35%] relative z-10">
              <p class="contact-reveal text-xs uppercase tracking-[0.3em] text-muted-foreground mb-5" style="font-style: italic; transition-delay: 0s;">Get In Touch</p>
              <h2 class="contact-reveal text-3xl font-medium tracking-tight text-foreground md:text-4xl lg:text-5xl" style="transition-delay: 0.08s;">
                Start a
                <span style="font-family: 'Playfair Display', serif; font-style: italic; font-weight: 500;">Conversation</span>
              </h2>
              <p class="contact-reveal mt-6 text-sm text-muted-foreground leading-relaxed" style="transition-delay: 0.16s;">
                Whether you want to join a Circle, partner with us, or simply learn more — we'd love to hear from you. Fill out the form and we'll get back to you soon.
              </p>
              <div class="contact-reveal mt-8 flex items-center gap-3" style="transition-delay: 0.24s;">
                <div class="w-8 h-[1px] bg-[#c49298]/40"></div>
                <p class="text-xs text-muted-foreground/60 tracking-wide" style="font-style: italic;">We respond within 48 hours</p>
              </div>
            </div>

            <!-- Right column — form -->
            <div class="md:w-[62%] lg:w-[65%]">
              <form class="space-y-8" action="https://api.web3forms.com/submit" method="POST" id="contact-form">
                <input type="hidden" name="access_key" value="e80680ce-9b98-4fe1-b6b5-58893c5fac01" />
                <input type="hidden" name="subject" value="New Contact from Flott Women's Circle" />
                <input type="hidden" name="from_name" value="Flott Website Contact" />
                <input type="checkbox" name="botcheck" class="hidden" style="display:none" />
                <!-- Name + Email row -->
                <div class="grid grid-cols-1 sm:grid-cols-2 gap-8">
                  <div class="contact-reveal" style="transition-delay: 0.1s;">
                    <label for="contact-name" class="block text-[11px] uppercase tracking-[0.25em] text-muted-foreground mb-3">Your Name</label>
                    <input
                      type="text"
                      id="contact-name"
                      name="name"
                      required
                      placeholder="Full name"
                      class="contact-input w-full bg-transparent border-0 border-b border-foreground/[0.12] px-0 py-3 text-sm text-foreground placeholder:text-foreground/20 outline-none transition-all duration-500 ease-[cubic-bezier(0.22,1,0.36,1)] focus:border-[#c49298]"
                    />
                  </div>
                  <div class="contact-reveal" style="transition-delay: 0.16s;">
                    <label for="contact-email" class="block text-[11px] uppercase tracking-[0.25em] text-muted-foreground mb-3">Email Address</label>
                    <input
                      type="email"
                      id="contact-email"
                      name="email"
                      required
                      placeholder="you@example.com"
                      class="contact-input w-full bg-transparent border-0 border-b border-foreground/[0.12] px-0 py-3 text-sm text-foreground placeholder:text-foreground/20 outline-none transition-all duration-500 ease-[cubic-bezier(0.22,1,0.36,1)] focus:border-[#c49298]"
                    />
                  </div>
                </div>

                <!-- Circle dropdown (custom) -->
                <div class="contact-reveal relative" style="transition-delay: 0.22s;">
                  <label class="block text-[11px] uppercase tracking-[0.25em] text-muted-foreground mb-3">Nearest Circle</label>
                  <input type="hidden" name="circle" id="contact-circle-value" />
                  <button
                    type="button"
                    id="circle-dropdown-btn"
                    class="w-full flex items-center justify-between bg-transparent border-0 border-b border-foreground/[0.12] px-0 py-3 text-sm text-left outline-none transition-all duration-500 ease-[cubic-bezier(0.22,1,0.36,1)] focus:border-[#c49298] cursor-pointer"
                  >
                    <span id="circle-dropdown-label" class="text-foreground/20">Select a city</span>
                    <svg class="w-3.5 h-3.5 text-foreground/30 transition-transform duration-300 ease-[cubic-bezier(0.22,1,0.36,1)]" id="circle-dropdown-chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6"/></svg>
                  </button>
                  <div id="circle-dropdown-menu" class="custom-dropdown-menu absolute left-0 right-0 top-full mt-1 rounded-lg overflow-hidden z-[100] opacity-0 pointer-events-none translate-y-[-8px] transition-all duration-300 ease-[cubic-bezier(0.22,1,0.36,1)]" style="background:#EBE7E2;box-shadow:0 8px 30px rgba(0,0,0,0.12),0 2px 8px rgba(0,0,0,0.08);border:1px solid rgba(15,9,6,0.1)">
                    <div class="py-1">
                      <button type="button" data-value="abuja" class="custom-dropdown-option w-full text-left px-4 py-2.5 text-sm text-foreground/70 transition-colors duration-200 hover:bg-foreground/[0.04] hover:text-foreground cursor-pointer">Abuja</button>
                      <button type="button" data-value="kaduna" class="custom-dropdown-option w-full text-left px-4 py-2.5 text-sm text-foreground/70 transition-colors duration-200 hover:bg-foreground/[0.04] hover:text-foreground cursor-pointer">Kaduna</button>
                      <button type="button" data-value="port-harcourt" class="custom-dropdown-option w-full text-left px-4 py-2.5 text-sm text-foreground/70 transition-colors duration-200 hover:bg-foreground/[0.04] hover:text-foreground cursor-pointer">Port Harcourt</button>
                      <button type="button" data-value="enugu" class="custom-dropdown-option w-full text-left px-4 py-2.5 text-sm text-foreground/70 transition-colors duration-200 hover:bg-foreground/[0.04] hover:text-foreground cursor-pointer">Enugu</button>
                      <button type="button" data-value="ilorin" class="custom-dropdown-option w-full text-left px-4 py-2.5 text-sm text-foreground/70 transition-colors duration-200 hover:bg-foreground/[0.04] hover:text-foreground cursor-pointer">Ilorin</button>
                      <button type="button" data-value="other" class="custom-dropdown-option w-full text-left px-4 py-2.5 text-sm text-foreground/70 transition-colors duration-200 hover:bg-foreground/[0.04] hover:text-foreground cursor-pointer">Other / Not Sure</button>
                    </div>
                  </div>
                </div>

                <!-- Message -->
                <div class="contact-reveal" style="transition-delay: 0.28s;">
                  <label for="contact-message" class="block text-[11px] uppercase tracking-[0.25em] text-muted-foreground mb-3">Your Message</label>
                  <textarea
                    id="contact-message"
                    name="message"
                    rows="4"
                    required
                    placeholder="Tell us what's on your mind..."
                    class="contact-input w-full bg-transparent border-0 border-b border-foreground/[0.12] px-0 py-3 text-sm text-foreground placeholder:text-foreground/20 outline-none transition-all duration-500 ease-[cubic-bezier(0.22,1,0.36,1)] focus:border-[#c49298] resize-none"
                  ></textarea>
                </div>

                <!-- Submit -->
                <div class="contact-reveal" style="transition-delay: 0.34s;">
                  <button
                    type="submit"
                    class="inline-flex items-center gap-2.5 rounded-full bg-foreground px-8 py-4 text-xs font-medium uppercase tracking-[0.15em] text-background transition-all duration-500 ease-[cubic-bezier(0.22,1,0.36,1)] hover:bg-foreground/85 hover:gap-4"
                  >
                    Send Message
                    <svg class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
                  </button>
                </div>
              </form>

              <!-- Success message (hidden by default) -->
              <div id="form-success" class="hidden mt-8 p-6 rounded-xl border border-[#c49298]/20 bg-[#c49298]/[0.06]">
                <div class="flex items-start gap-3">
                  <svg class="w-5 h-5 text-[#c49298] mt-0.5 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
                  <div>
                    <p class="text-sm font-medium text-foreground">Message sent successfully!</p>
                    <p class="text-xs text-muted-foreground mt-1">Thank you for reaching out. We'll get back to you as soon as possible.</p>
                  </div>
                </div>
              </div>
            </div>

          </div>
        </div>
      </div>
    </section>

    <!-- 5 Circle Locations — SVG Circle Network -->
    <section class="bg-background relative overflow-hidden py-12 md:py-16 lg:py-20">

      <!-- Decorative paisley — top right -->
      <svg class="absolute top-20 right-4 w-[100px] h-[140px] md:w-[130px] md:h-[185px] text-[#e8b4b8] opacity-[0.18] pointer-events-none" viewBox="0 0 300 420" fill="none" stroke="currentColor" stroke-width="0.9" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M150 400 C100 350 40 280 40 190 C40 100 85 40 150 20 C215 40 260 100 260 190 C260 280 200 350 150 400Z" />
        <path d="M150 350 C115 315 75 265 75 195 C75 130 105 85 150 68 C195 85 225 130 225 195 C225 265 185 315 150 350Z" />
        <path d="M150 210 C150 202 158 197 164 200 C170 203 168 214 162 216 C156 218 148 214 147 206" />
      </svg>

      <!-- Decorative floral — bottom left -->
      <svg class="absolute bottom-12 left-4 w-[80px] h-[80px] md:w-[120px] md:h-[120px] text-[#e8b4b8] opacity-[0.15] pointer-events-none" viewBox="0 0 200 200" fill="none" stroke="currentColor" stroke-width="0.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <circle cx="100" cy="100" r="4" />
        <path d="M100 92 Q104 80 100 68 Q96 80 100 92Z" />
        <path d="M108 96 Q120 92 128 82 Q118 90 108 96Z" />
        <path d="M108 106 Q120 110 128 120 Q118 112 108 106Z" />
        <path d="M100 110 Q104 122 100 134 Q96 122 100 110Z" />
        <path d="M92 106 Q80 110 72 120 Q82 112 92 106Z" />
        <path d="M92 96 Q80 92 72 82 Q82 90 92 96Z" />
        <circle cx="100" cy="100" r="28" />
        <circle cx="100" cy="100" r="50" />
      </svg>

      <!-- Section header -->
      <div class="px-6 md:px-12 lg:px-20 mb-10 md:mb-12 lg:mb-16 relative z-10">
        <p class="contact-reveal text-xs uppercase tracking-[0.3em] text-muted-foreground mb-4" style="font-style: italic; transition-delay: 0s;">Our Circles</p>
        <h2 class="contact-reveal text-3xl font-medium tracking-tight text-foreground md:text-4xl lg:text-5xl" style="transition-delay: 0.1s;">
          5 Cities,
          <span style="font-family: 'Playfair Display', serif; font-style: italic; font-weight: 500;">One Community</span>
        </h2>
        <p class="contact-reveal mt-4 text-sm text-muted-foreground max-w-md leading-relaxed" style="transition-delay: 0.2s;">
          Find your Circle. DM us on Instagram or visit any of our locations across Nigeria.
        </p>
      </div>

      <!-- 5 Circles — staggered row -->
      <div class="circles-row relative px-6 md:px-12 lg:px-16 xl:px-20">
        <div class="flex flex-wrap justify-center gap-8 md:gap-10 lg:flex-nowrap lg:justify-between lg:gap-0">
          {circles.map((circle, i) => (
            <a
              href={circle.instagramUrl || undefined}
              target={circle.instagramUrl ? "_blank" : undefined}
              rel={circle.instagramUrl ? "noopener noreferrer" : undefined}
              class={`circle-item contact-reveal flex flex-col items-center w-[42%] md:w-[28%] lg:w-auto lg:flex-1 no-underline ${circle.instagramUrl ? 'cursor-pointer' : 'cursor-default'}`}
              style={`transition-delay: ${0.15 + i * 0.08}s;`}
            >
              <div class="flex flex-col items-center" style={`--stagger: ${circle.offset}px`}>

                <!-- The circle -->
                <div class="circle-ring relative w-[140px] h-[140px] md:w-[160px] md:h-[160px] lg:w-[170px] lg:h-[170px] xl:w-[200px] xl:h-[200px] rounded-full border border-foreground/[0.1] flex flex-col items-center justify-center">

                  <!-- Inner dashed ring -->
                  <div class="absolute inset-3 md:inset-3.5 rounded-full border border-dashed border-foreground/[0.04]"></div>

                  <!-- Perimeter dots — 4 cardinal points -->
                  <div class="absolute -top-[3px] left-1/2 -translate-x-1/2 w-1.5 h-1.5 rounded-full bg-foreground/[0.08]"></div>
                  <div class="absolute -bottom-[3px] left-1/2 -translate-x-1/2 w-1.5 h-1.5 rounded-full bg-foreground/[0.08]"></div>
                  <div class="absolute top-1/2 -left-[3px] -translate-y-1/2 w-1.5 h-1.5 rounded-full bg-foreground/[0.08]"></div>
                  <div class="absolute top-1/2 -right-[3px] -translate-y-1/2 w-1.5 h-1.5 rounded-full bg-foreground/[0.08]"></div>

                  <!-- Number -->
                  <span
                    class="circle-item-num text-2xl md:text-3xl xl:text-4xl font-light text-foreground/[0.07]"
                    style="font-family: 'Playfair Display', serif; font-style: italic;"
                  >
                    {String(i + 1).padStart(2, '0')}
                  </span>

                  <!-- City name -->
                  <h3 class="circle-item-city mt-1 text-sm md:text-base xl:text-lg font-medium text-foreground/40 tracking-tight">
                    {circle.city}
                  </h3>
                </div>

                <!-- Details below circle -->
                <div class="circle-item-details mt-5 text-center min-h-[52px] flex flex-col justify-start">
                  {circle.address ? (
                    <>
                      <p class="text-[11px] text-muted-foreground leading-relaxed">{circle.address}</p>
                      <a href={circle.instagramUrl} target="_blank" rel="noopener noreferrer" class="mt-1.5 block text-[11px] text-[#c49298] tracking-wide no-underline transition-colors duration-400 hover:text-primary">{circle.instagram}</a>
                    </>
                  ) : (
                    <p class="text-[11px] text-muted-foreground italic">Coming soon</p>
                  )}
                </div>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- Philosophy Quote + CTA -->
    <section class="bg-background relative overflow-hidden">
      <svg class="absolute -top-8 -right-12 w-[140px] h-[140px] md:w-[200px] md:h-[200px] text-[#e8b4b8] opacity-[0.25] pointer-events-none" viewBox="0 0 400 400" fill="none" stroke="currentColor" stroke-width="0.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <circle cx="200" cy="200" r="30" />
        <circle cx="200" cy="200" r="50" />
        <path d="M200 148 Q206 134 200 120 Q194 134 200 148Z" />
        <path d="M252 194 Q266 188 278 178 Q264 190 252 194Z" />
        <path d="M200 252 Q206 266 200 278 Q194 266 200 252Z" />
        <path d="M148 194 Q134 188 122 178 Q136 190 148 194Z" />
        <circle cx="200" cy="200" r="80" />
      </svg>

      <div class="px-6 py-8 md:px-12 md:py-10 lg:px-20 lg:py-14">
        <ScrollRevealText
          client:visible
          text="Every Circle starts with one step. Yours is here."
          className="mx-auto max-w-4xl text-2xl leading-relaxed md:text-3xl lg:text-[2.3rem] lg:leading-snug"
          accentWords={["Circle", "here"]}
        />
      </div>

      <div class="relative aspect-[16/9] sm:aspect-[21/9] lg:aspect-[32/9] w-full reveal">
        <img src="/images/flott-footer-img.webp" alt="Flott Women's Circle community" class="absolute inset-0 w-full h-full object-cover" />
        <div class="absolute inset-0 bg-gradient-to-t from-background via-background/40 to-black/30"></div>
        <div class="absolute inset-0 flex items-end px-6 pb-6 sm:px-8 sm:pb-8 md:px-14 md:pb-12 lg:px-20 lg:pb-16">
          <div class="contact-cta-words" style="text-indent: -0.04em;">
            <h2 class="text-3xl sm:text-4xl md:text-6xl lg:text-7xl xl:text-8xl font-medium leading-[1.05] tracking-tight">
              <span class="contact-cta-w" style="transition-delay: 0s;">Come</span>{" "}
              <span class="contact-cta-w" style="transition-delay: 0.15s;">As</span>{" "}
              <span class="contact-cta-w" style="transition-delay: 0.3s;">You</span>{" "}
              <span class="contact-cta-w" style="transition-delay: 0.45s; font-family: 'Playfair Display', serif; font-style: italic; font-weight: 500;">Are.</span>
            </h2>
            <p class="contact-cta-sub mt-3 md:mt-5 text-xs md:text-sm font-normal tracking-[0.2em] uppercase">Flott Women's Circle</p>
          </div>
        </div>
      </div>
    </section>

    <FooterSection />
  </main>
</Layout>

<style>
  .contact-reveal {
    opacity: 0;
    transform: translateY(24px);
    filter: blur(6px);
    will-change: opacity, transform, filter;
    transition:
      opacity 1.2s cubic-bezier(0.22, 1, 0.36, 1),
      transform 1.2s cubic-bezier(0.22, 1, 0.36, 1),
      filter 1.4s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .contact-reveal.visible {
    opacity: 1;
    transform: translateY(0);
    filter: blur(0);
  }

  /* Circle interactions — CSS only */
  .circle-item {
    transition: opacity 0.8s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .circle-ring {
    transition:
      border-color 0.8s cubic-bezier(0.22, 1, 0.36, 1),
      box-shadow 0.8s cubic-bezier(0.22, 1, 0.36, 1),
      background 0.8s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .circle-item-num {
    transition: color 0.8s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .circle-item-city {
    transition: color 0.8s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .circle-item-details * {
    transition: color 0.8s cubic-bezier(0.22, 1, 0.36, 1);
  }

  /* Hover: dim siblings, brighten active */
  .circles-row:hover .circle-item {
    opacity: 0.3;
  }
  .circles-row:hover .circle-item:hover {
    opacity: 1;
  }

  /* Active circle glow */
  .circle-item:hover .circle-ring {
    border-color: rgba(196, 146, 152, 0.45);
    box-shadow: 0 0 60px rgba(196, 146, 152, 0.12), inset 0 0 30px rgba(196, 146, 152, 0.05);
    background: rgba(196, 146, 152, 0.04);
  }
  .circle-item:hover .circle-item-num {
    color: rgba(15, 9, 6, 0.2) !important;
  }
  .circle-item:hover .circle-item-city {
    color: rgba(15, 9, 6, 1) !important;
  }
  .circle-item:hover .circle-item-details p {
    color: rgba(15, 9, 6, 0.6);
  }
  .circle-item:hover .circle-item-details p:last-child {
    color: #c49298;
  }

  /* Vertical stagger — desktop only */
  @media (min-width: 1024px) {
    .circle-item > div {
      transform: translateY(var(--stagger, 0));
    }
  }

  .contact-cta-w {
    color: transparent;
    filter: blur(8px);
    will-change: color, filter;
    transition:
      color 1.2s cubic-bezier(0.22, 1, 0.36, 1),
      filter 1.6s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .contact-cta-words.visible .contact-cta-w {
    color: #0F0906;
    filter: blur(0);
  }
  .contact-cta-sub {
    color: transparent;
    filter: blur(6px);
    will-change: color, filter;
    transition:
      color 1.2s cubic-bezier(0.22, 1, 0.36, 1) 0.9s,
      filter 1.6s cubic-bezier(0.22, 1, 0.36, 1) 0.9s;
  }
  .contact-cta-words.visible .contact-cta-sub {
    color: rgb(15 9 6 / 0.6);
    filter: blur(0);
  }
</style>

<script>
  // Scroll reveal
  const contactObs = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add("visible");
          contactObs.unobserve(entry.target);
        }
      });
    },
    { threshold: 0.05 }
  );
  document.querySelectorAll(".contact-reveal").forEach((el) => contactObs.observe(el));

  // CTA word reveal
  const ctaContactObs = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add("visible");
          ctaContactObs.unobserve(entry.target);
        }
      });
    },
    { threshold: 0.05 }
  );
  document.querySelectorAll(".contact-cta-words").forEach((el) => ctaContactObs.observe(el));

  // Custom dropdown
  const btn = document.getElementById("circle-dropdown-btn");
  const menu = document.getElementById("circle-dropdown-menu");
  const label = document.getElementById("circle-dropdown-label");
  const chevron = document.getElementById("circle-dropdown-chevron");
  const hidden = document.getElementById("contact-circle-value");
  let open = false;

  function toggle() {
    open = !open;
    if (open) {
      menu.style.opacity = "1";
      menu.style.pointerEvents = "auto";
      menu.style.transform = "translateY(0)";
      chevron.style.transform = "rotate(180deg)";
    } else {
      menu.style.opacity = "0";
      menu.style.pointerEvents = "none";
      menu.style.transform = "translateY(-8px)";
      chevron.style.transform = "rotate(0)";
    }
  }

  btn.addEventListener("click", toggle);

  document.querySelectorAll(".custom-dropdown-option").forEach((opt) => {
    opt.addEventListener("click", () => {
      label.textContent = opt.textContent;
      label.classList.remove("text-foreground/20");
      label.classList.add("text-foreground");
      hidden.value = opt.dataset.value;
      toggle();
    });
  });

  document.addEventListener("click", (e) => {
    if (open && !btn.contains(e.target) && !menu.contains(e.target)) toggle();
  });

  // Form submission via fetch (no page redirect)
  const contactForm = document.getElementById("contact-form") as HTMLFormElement;
  const submitBtn = contactForm?.querySelector('button[type="submit"]') as HTMLButtonElement;
  const submitText = submitBtn?.querySelector('svg')?.previousSibling;
  const successMsg = document.getElementById("form-success");

  contactForm?.addEventListener("submit", async (e) => {
    e.preventDefault();
    submitBtn.disabled = true;
    if (submitText) submitText.textContent = "Sending... ";

    try {
      const res = await fetch("https://api.web3forms.com/submit", {
        method: "POST",
        body: new FormData(contactForm),
      });
      const data = await res.json();

      if (data.success) {
        contactForm.reset();
        if (submitText) submitText.textContent = "Send Message ";
        submitBtn.disabled = false;
        label.textContent = "Select a city";
        label.classList.remove("text-foreground");
        label.classList.add("text-foreground/20");
        hidden.value = "";
        // Show success message
        if (successMsg) {
          successMsg.classList.remove("hidden");
          successMsg.scrollIntoView({ behavior: "smooth", block: "nearest" });
          setTimeout(() => successMsg.classList.add("hidden"), 8000);
        }
      } else {
        throw new Error();
      }
    } catch {
      if (submitText) submitText.textContent = "Failed — Try Again ";
      submitBtn.disabled = false;
    }
  });
</script>
