---
import Layout from "../layouts/Layout.astro";
import { Header } from "../components/Header";
import FooterSection from "../components/FooterSection.astro";

const galleryImages = Array.from({ length: 64 }, (_, i) => ({
  src: `/images/gallery/event-${String(i + 1).padStart(2, "0")}.webp`,
  alt: `Flott Women's Circle event ${i + 1}`,
}));

// Split into columns for masonry-like layout
const col1 = galleryImages.filter((_, i) => i % 3 === 0);
const col2 = galleryImages.filter((_, i) => i % 3 === 1);
const col3 = galleryImages.filter((_, i) => i % 3 === 2);
---

<Layout title="Gallery - Flott Women's Circle">
  <main class="min-h-screen bg-background overflow-x-clip">
    <Header client:load innerPage={true} currentPath="/gallery" />

    <!-- Hero -->
    <section class="relative pt-32 pb-12 md:pt-40 md:pb-16 px-6 md:px-12 lg:px-20 overflow-hidden">
      <svg class="absolute top-24 -right-10 w-[140px] h-[140px] md:w-[200px] md:h-[200px] text-[#e8b4b8] opacity-[0.25] pointer-events-none" viewBox="0 0 100 100" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <circle cx="50" cy="50" r="4" />
        <path d="M50 42 Q54 30 50 20 Q46 30 50 42Z" />
        <path d="M58 46 Q68 40 74 32 Q64 38 58 46Z" />
        <path d="M58 54 Q68 60 74 68 Q64 62 58 54Z" />
        <path d="M50 58 Q54 70 50 80 Q46 70 50 58Z" />
        <path d="M42 54 Q32 60 26 68 Q36 62 42 54Z" />
        <path d="M42 46 Q32 40 26 32 Q36 38 42 46Z" />
        <circle cx="50" cy="16" r="1.5" /><circle cx="76" cy="30" r="1.5" /><circle cx="76" cy="70" r="1.5" />
        <circle cx="50" cy="84" r="1.5" /><circle cx="24" cy="70" r="1.5" /><circle cx="24" cy="30" r="1.5" />
      </svg>

      <p class="blur-words text-xs uppercase tracking-[0.3em] text-muted-foreground mb-4" style="font-style: italic">Gallery</p>
      <h1 class="word-blur-group text-4xl font-medium tracking-tight text-foreground md:text-5xl lg:text-6xl max-w-3xl">
        <span class="word-blur" style="transition-delay: 0.05s">Real</span>
        <span class="word-blur" style="transition-delay: 0.12s">Women.</span>
        <span class="word-blur" style="transition-delay: 0.22s">Real</span>
        <span class="word-blur" style="transition-delay: 0.35s; font-family: 'Playfair Display', serif; font-style: italic; font-weight: 500;">Moments.</span>
      </h1>
    </section>

    <!-- Masonry Gallery -->
    <section class="px-6 pb-20 md:px-12 md:pb-28 lg:px-20 lg:pb-36">
      <div class="columns-2 lg:columns-3 gap-4 space-y-4">
        {galleryImages.map((image, i) => (
          <div class="reveal break-inside-avoid" style={`transition-delay: ${(i % 6) * 0.06}s`}>
            <div class="relative overflow-hidden rounded-xl group">
              <img
                src={image.src}
                alt={image.alt}
                class="fade-image w-full h-auto object-cover hover-zoom"
                loading="lazy"


              />
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- CTA -->
    <section class="px-6 pb-20 md:px-12 md:pb-28 lg:px-20 lg:pb-36 text-center">
      <div class="reveal">
        <p class="text-lg font-medium text-foreground mb-2" style="font-family: 'Playfair Display', serif; font-style: italic;">Be part of our story.</p>
        <p class="text-sm text-muted-foreground mb-6">These are our moments. Come make yours.</p>
        <a href="/contact" class="inline-flex items-center gap-2 bg-primary text-primary-foreground px-8 py-4 rounded-full text-sm font-medium transition-opacity hover:opacity-80">
          Join a Circle
          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </a>
      </div>
    </section>

    <FooterSection />
  </main>
</Layout>
