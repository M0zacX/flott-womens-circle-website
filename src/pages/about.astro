<style>
  /* Differentiator section reveal animation */
  .diff-reveal {
    opacity: 0;
    transform: translateY(24px);
    filter: blur(6px);
    will-change: opacity, transform, filter;
    transition:
      opacity 1.2s cubic-bezier(0.22, 1, 0.36, 1),
      transform 1.2s cubic-bezier(0.22, 1, 0.36, 1),
      filter 1.4s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .diff-reveal.visible {
    opacity: 1;
    transform: translateY(0);
    filter: blur(0);
  }

  /* CTA word reveal */
  .about-cta-w {
    color: transparent;
    filter: blur(8px);
    will-change: color, filter;
    transition:
      color 1.2s cubic-bezier(0.22, 1, 0.36, 1),
      filter 1.6s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .about-cta-words.visible .about-cta-w {
    color: #0F0906;
    filter: blur(0);
  }
  .about-cta-sub {
    color: transparent;
    filter: blur(6px);
    will-change: color, filter;
    transition:
      color 1.2s cubic-bezier(0.22, 1, 0.36, 1) 0.9s,
      filter 1.6s cubic-bezier(0.22, 1, 0.36, 1) 0.9s;
  }
  .about-cta-words.visible .about-cta-sub {
    color: rgb(15 9 6 / 0.6);
    filter: blur(0);
  }
</style>

<script>
  // Differentiator section — scroll reveal
  const diffObs = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add("visible");
          diffObs.unobserve(entry.target);
        }
      });
    },
    { threshold: 0.05 }
  );
  document.querySelectorAll(".diff-reveal").forEach((el) => diffObs.observe(el));

  // Differentiator row interactions (background crossfade)
  const diffSection = document.querySelector(".about-diff-section");
  if (diffSection) {
    const rows = diffSection.querySelectorAll(".diff-row");
    const bgs = diffSection.querySelectorAll(".diff-bg");
    let activeIndex = -1;

    const activateRow = (index) => {
      if (index === activeIndex) return;
      activeIndex = index;

      // Crossfade backgrounds
      bgs.forEach((bg, i) => {
        const img = bg.querySelector("img");
        if (i === index) {
          bg.style.opacity = "1";
          bg.style.zIndex = "1";
          if (img) img.style.transform = "scale(1)";
        } else {
          bg.style.opacity = "0";
          bg.style.zIndex = "0";
          if (img) img.style.transform = "scale(1.08)";
        }
      });

      // Highlight active row, dim others
      rows.forEach((r) => {
        const isActive = r.getAttribute("data-row-index") === String(index);
        const num = r.querySelector(".diff-number");
        const icon = r.querySelector(".diff-icon");
        const title = r.querySelector(".diff-title");
        const content = r.querySelector(".diff-content");
        const desc = r.querySelector(".diff-desc");
        const arrow = r.querySelector(".diff-arrow");

        if (num) num.style.color = isActive ? "rgba(255,255,255,0.6)" : "rgba(255,255,255,0.05)";
        if (icon) { icon.style.opacity = isActive ? "1" : "0"; icon.style.transform = isActive ? "scale(1)" : "scale(0.8)"; }
        if (title) title.style.color = isActive ? "rgba(255,255,255,1)" : "rgba(255,255,255,0.15)";
        if (content) content.style.transform = isActive ? "translateY(0)" : "translateY(8px)";
        if (desc) desc.style.opacity = isActive ? "1" : "0";
        if (arrow) {
          arrow.style.opacity = isActive ? "1" : "0";
          arrow.style.transform = isActive ? "translateX(0)" : "translateX(-10px)";
        }
      });
    };

    // Initialize first row as active
    activateRow(0);

    // Scroll-activated rows
    const rowScrollObs = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            const index = parseInt(entry.target.getAttribute("data-row-index") || "0");
            activateRow(index);
          }
        });
      },
      { rootMargin: "-25% 0px -50% 0px", threshold: 0 }
    );
    rows.forEach((row) => rowScrollObs.observe(row));

    // Hover interactions
    let hoverTimer = null;
    rows.forEach((row) => {
      row.addEventListener("mouseenter", () => {
        clearTimeout(hoverTimer);
        const index = parseInt(row.getAttribute("data-row-index") || "0");
        hoverTimer = setTimeout(() => activateRow(index), 150);
      });
    });

    const list = diffSection.querySelector(".diff-list");
    if (list) {
      list.addEventListener("mouseleave", () => {
        clearTimeout(hoverTimer);
      });
    }
  }

  // CTA words reveal
  const aboutCtaObs = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add("visible");
          aboutCtaObs.unobserve(entry.target);
        }
      });
    },
    { threshold: 0.05 }
  );
  document.querySelectorAll(".about-cta-words").forEach((el) => aboutCtaObs.observe(el));
</script>
