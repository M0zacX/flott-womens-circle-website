---
import Layout from "../layouts/Layout.astro";
import { Header } from "../components/Header";
import FooterSection from "../components/FooterSection.astro";

const focusAreas = [
  {
    title: "Wellness Education",
    description: "Body care, emotional balance, rest, and self-care — taught in ways that honour your culture and fit your life.",
    image: "/images/gallery/event-03.jpeg",
  },
  {
    title: "Soft Skills Acquisition",
    description: "Communication, confidence, emotional intelligence, boundaries, and self-management — the skills that change everything.",
    image: "/images/gallery/event-15.jpeg",
  },
  {
    title: "Women Empowerment",
    description: "Mental, social, economic, and financial empowerment. Four dimensions. One goal: your growth.",
    image: "/images/gallery/event-22.jpeg",
  },
  {
    title: "Community & Connection",
    description: "A space where you're seen, heard, and supported. No judgement. No comparison. Just belonging.",
    image: "/images/gallery/event-30.jpeg",
  },
];

const dimensions = [
  { label: "Mental", text: "Inner strength, self-awareness, and the resilience to navigate life with clarity" },
  { label: "Social", text: "Meaningful relationships and the confidence to express who you really are" },
  { label: "Economic", text: "Practical skills and knowledge for building sustainable livelihoods" },
  { label: "Financial", text: "Real confidence around money — budgeting, planning, and financial independence" },
];

const goals = [
  "Help more women understand wellness — and practice it daily",
  "Strengthen personal and emotional skills across communities",
  "Support women's mental health and social wellbeing",
  "Increase economic participation and financial confidence",
  "Build lasting, supportive communities in every city",
  "Create empowerment programs that can scale across Nigeria",
];
---

<Layout title="Focus Areas - Flott Women's Circle">
  <main class="min-h-screen bg-background overflow-x-clip">
    <Header client:load innerPage={true} currentPath="/focus-areas" />

    <!-- Hero -->
    <section class="relative pt-32 pb-16 md:pt-40 md:pb-24 px-6 md:px-12 lg:px-20 overflow-hidden">
      <svg class="absolute -top-8 -right-16 w-[180px] h-[180px] md:w-[260px] md:h-[260px] text-[#e8b4b8] opacity-[0.3] pointer-events-none" viewBox="0 0 100 100" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <circle cx="50" cy="50" r="4" />
        <path d="M50 42 Q54 30 50 20 Q46 30 50 42Z" />
        <path d="M58 46 Q68 40 74 32 Q64 38 58 46Z" />
        <path d="M58 54 Q68 60 74 68 Q64 62 58 54Z" />
        <path d="M50 58 Q54 70 50 80 Q46 70 50 58Z" />
        <path d="M42 54 Q32 60 26 68 Q36 62 42 54Z" />
        <path d="M42 46 Q32 40 26 32 Q36 38 42 46Z" />
        <circle cx="50" cy="16" r="1.5" /><circle cx="76" cy="30" r="1.5" /><circle cx="76" cy="70" r="1.5" />
        <circle cx="50" cy="84" r="1.5" /><circle cx="24" cy="70" r="1.5" /><circle cx="24" cy="30" r="1.5" />
      </svg>

      <p class="blur-words text-xs uppercase tracking-[0.3em] text-muted-foreground mb-4" style="font-style: italic">Where We Go Deep</p>
      <h1 class="word-blur-group text-4xl font-medium tracking-tight text-foreground md:text-5xl lg:text-6xl max-w-3xl">
        <span class="word-blur" style="transition-delay: 0.05s">Our</span>
        <span class="word-blur" style="transition-delay: 0.12s">Focus</span>
        <span class="word-blur" style="transition-delay: 0.25s; font-family: 'Playfair Display', serif; font-style: italic; font-weight: 500;">Areas</span>
      </h1>
      <p class="blur-words mt-6 text-base text-muted-foreground max-w-xl leading-relaxed">
        Four pillars that shape every session, every space, and every conversation.
      </p>
    </section>

    <!-- Focus Areas Grid -->
    <section class="px-6 pb-16 md:px-12 md:pb-24 lg:px-20 lg:pb-28">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 lg:gap-8">
        {focusAreas.map((area, i) => (
          <div class="reveal group" style={`transition-delay: ${i * 0.12}s`}>
            <div class="relative aspect-[4/3] overflow-hidden rounded-2xl reveal-clip" style={`transition-delay: ${0.05 + i * 0.12}s`}>
              <img
                src={area.image}
                alt={area.title}
                class="fade-image absolute inset-0 w-full h-full object-cover hover-zoom"
                loading="lazy"
                onload="this.classList.add('loaded')"
              />
              <div class="absolute inset-0 bg-gradient-to-t from-black/60 via-black/20 to-transparent"></div>
              <div class="absolute inset-x-0 bottom-0 p-6 md:p-8">
                <h3 class="text-xl md:text-2xl font-medium text-white">{area.title}</h3>
                <p class="mt-2 text-sm text-white/70 leading-relaxed max-w-md">{area.description}</p>
              </div>
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- Empowerment Dimensions -->
    <section class="bg-foreground text-background px-6 py-16 md:px-12 md:py-24 lg:px-20 lg:py-28">
      <div class="max-w-5xl mx-auto">
        <p class="blur-words text-xs uppercase tracking-[0.3em] text-background/50 mb-4" style="font-style: italic">Empowerment</p>
        <h2 class="word-blur-group text-2xl font-medium tracking-tight md:text-3xl lg:text-4xl mb-14">
          <span class="word-blur" style="transition-delay: 0.05s; color: var(--color-background)">Four</span>
          <span class="word-blur" style="transition-delay: 0.12s; color: var(--color-background)">Dimensions</span>
          <span class="word-blur" style="transition-delay: 0.2s; color: var(--color-background)">of</span>
          <span class="word-blur" style="transition-delay: 0.32s; color: var(--color-background); font-family: 'Playfair Display', serif; font-style: italic; font-weight: 500;">Growth</span>
        </h2>

        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8">
          {dimensions.map((dim, i) => (
            <div class="reveal border-t border-background/15 pt-6" style={`transition-delay: ${i * 0.12}s`}>
              <span class="text-3xl font-light text-background/20">0{i + 1}</span>
              <h3 class="mt-3 text-base font-semibold text-background">{dim.label}</h3>
              <p class="mt-2 text-xs leading-relaxed text-background/60">{dim.text}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Impact Goals -->
    <section class="px-6 py-16 md:px-12 md:py-24 lg:px-20 lg:py-28 relative overflow-hidden">
      <svg class="absolute bottom-12 -right-8 w-[120px] h-[170px] md:w-[160px] md:h-[230px] text-[#e8b4b8] opacity-[0.25] pointer-events-none" viewBox="0 0 300 420" fill="none" stroke="currentColor" stroke-width="1.1" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" style="transform: rotate(-10deg)">
        <path d="M150 400 C100 350 40 280 40 190 C40 100 85 40 150 20 C215 40 260 100 260 190 C260 280 200 350 150 400Z" />
        <path d="M150 350 C115 315 75 265 75 195 C75 130 105 85 150 68 C195 85 225 130 225 195 C225 265 185 315 150 350Z" />
        <path d="M150 210 C150 202 158 197 164 200 C170 203 168 214 162 216 C156 218 148 214 147 206" />
      </svg>

      <div class="max-w-3xl mx-auto">
        <p class="blur-words text-xs uppercase tracking-[0.3em] text-muted-foreground mb-4 text-center" style="font-style: italic">Looking Ahead</p>
        <h2 class="word-blur-group text-2xl font-medium tracking-tight text-foreground md:text-3xl lg:text-4xl text-center mb-14">
          <span class="word-blur" style="transition-delay: 0.05s">Impact</span>
          <span class="word-blur" style="transition-delay: 0.15s; font-family: 'Playfair Display', serif; font-style: italic; font-weight: 500;">Goals</span>
        </h2>

        <div class="space-y-6">
          {goals.map((goal, i) => (
            <div class="reveal flex items-start gap-4 border-b border-border pb-6" style={`transition-delay: ${i * 0.08}s`}>
              <span class="text-xs font-medium text-primary mt-0.5">0{i + 1}</span>
              <p class="text-sm leading-relaxed text-foreground">{goal}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <FooterSection />
  </main>
</Layout>
